# dev/.env.example
# Copy to dev/.env and fill in the values.
# NEVER commit .env — it contains the encryption master key.

# Bearer token presented by the MCP server (MEMO_TOKEN env var).
MEMO_TOKEN=dev-token

# 64-char hex master key for AES-256-CBC + HMAC-SHA256 secret encryption.
# Generate with: openssl rand -hex 32
# MEMO_MASTER_KEY=<paste your key here>
