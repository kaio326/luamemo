# memo context QUERY [--scope SCOPE] [--limit N] [--no-kg] [--format text|json]
cmd_context() {
    require_jq
    local q="${1:-}"
    if [[ -z "$q" ]]; then
        echo "Usage: memo context QUERY [--scope SCOPE] [--limit N] [--no-kg] [--format text|json]" >&2
        exit 1
    fi
    shift

    local scope="" limit=10 no_kg=false format="text"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope)  scope="$2";  shift 2 ;;
            --limit)  limit="$2";  shift 2 ;;
            --no-kg)  no_kg=true;  shift   ;;
            --format) format="$2"; shift 2 ;;
            *) echo "memo context: unknown arg: $1" >&2; exit 1 ;;
        esac
    done

    local json; json=$(jq -n \
        --arg q "$q" \
        --arg scope "$scope" \
        --argjson limit "$limit" \
        --arg format "$format" \
        '{q: $q, limit: $limit, format: $format}
         | if $scope != "" then . + {scope: $scope} else . end')
    [[ "$no_kg" == true ]] && json=$(printf '%s' "$json" | jq '. + {no_kg: true}')

    local result; result=$(printf '%s' "$json" | api_call context)
    if [[ "$format" == "json" ]]; then
        printf '%s' "$result" | jq .
    else
        printf '%s' "$result" | jq -r '.text // "(no context)"'
    fi
}

# memo brief [--scope SCOPE]
# Print a tiny session-start digest (memory + codebase-map status + tool hints).
# No query required. Defaults --scope to $MEMO_SCOPE. Never fails the caller —
# designed to be run from a SessionStart hook and injected into the session.
cmd_brief() {
    require_jq
    local scope="${MEMO_SCOPE:-}"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope) scope="$2"; shift 2 ;;
            *) shift ;;   # ignore unknown args to stay robust in hook contexts
        esac
    done

    local json; json=$(jq -n --arg scope "$scope" \
        '{} | if $scope != "" then . + {scope: $scope} else . end')

    local lua; lua=$(find_lua) || return 0

    # Hard cap: a session-start hook must never block. If the DB is slow or
    # unreachable and the query hangs, `timeout` kills it and we print nothing.
    # -k 2: if the process ignores SIGTERM (e.g. blocked in a socket syscall),
    # SIGKILL it 2s later so no orphan lua process lingers after the hook.
    local runner=""
    command -v timeout >/dev/null 2>&1 && runner="timeout -k 2 ${MEMO_BRIEF_TIMEOUT:-5}"
    local result; result=$(printf '%s' "$json" | $runner "$lua" -e \
        "package.path='./?/init.lua;'..package.path; require('luamemo.cli.api').dispatch('brief')" \
        2>/dev/null) || true
    local text; text=$(printf '%s' "$result" | jq -r '.text // empty' 2>/dev/null) || true
    [[ -n "$text" ]] && printf '%s\n' "$text"
    return 0
}

