# ---------------------------------------------------------------------------
# _check_col_list <newline-separated-column-list>
# Shared inner loop: given a newline-separated string of present column names,
# prints ✓/✗ for each name in _MEMO_REQUIRED_COLS[@].
# Returns 0 if all present, 1 if any missing.
# ---------------------------------------------------------------------------
_check_col_list() {
    local _list="$1"
    local _ok=true
    for _col in "${_MEMO_REQUIRED_COLS[@]}"; do
        if printf '%s\n' "$_list" | grep -qx "$_col"; then
            printf "  ✓ %s\n" "$_col"
        else
            printf "  ✗ %s — MISSING\n" "$_col"
            _ok=false
        fi
    done
    [[ "$_ok" == "true" ]]
}

# ---------------------------------------------------------------------------
# _check_mem_columns <psql_url>
# Shared helper: queries lm_memories columns and prints ✓/✗ per required
# column from _MEMO_REQUIRED_COLS.
# Return codes:
#   0 — all columns present
#   1 — one or more columns missing
#   2 — table not found / DB unreachable (present_cols was empty)
# Does NOT call exit — the caller decides how to handle each code.
# ---------------------------------------------------------------------------
_check_mem_columns() {
    local _db="$1"
    local _present
    _present=$(PGPASSWORD="${PGPASSWORD:-}" psql "$_db" -tAc \
        "SELECT column_name FROM information_schema.columns \
         WHERE table_schema='public' AND table_name='lm_memories'" 2>/dev/null || true)
    if [[ -z "$_present" ]]; then
        return 2
    fi
    _check_col_list "$_present"
}

# ---------------------------------------------------------------------------
# _cmd_migrate_check: diff required columns vs live DB via psql.
# Exits 0 if schema is complete, 1 if anything is missing.
# ---------------------------------------------------------------------------
_cmd_migrate_check() {
    local embed_dim="${1:-384}"
    if [[ -z "${MEMO_DB_URL:-}" ]]; then
        echo "memo migrate --check: MEMO_DB_URL is not set." >&2
        exit 1
    fi
    if ! command -v psql &>/dev/null; then
        echo "memo migrate --check: psql not found in PATH." >&2
        exit 1
    fi
    local _rc
    _check_mem_columns "$MEMO_DB_URL"; _rc=$?
    if [[ "$_rc" -eq 2 ]]; then
        echo "  ✗ lm_memories — table not found or DB unreachable"
        echo "    Is MEMO_DB_URL correct? Run: memo migrate | psql \"\$MEMO_DB_URL\""
        exit 1
    fi
    echo ""
    if [[ "$_rc" -eq 0 ]]; then
        echo "Schema is complete."
    else
        echo "Run: memo migrate | psql \"\$MEMO_DB_URL\"  to apply missing columns."
        exit 1
    fi
}


# memo migrate [--embed-dim N] [--check]
cmd_migrate() {
    local embed_dim=384
    local check_mode=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --embed-dim) embed_dim="$2"; shift 2 ;;
            --check)     check_mode=true; shift ;;
            *) echo "memo migrate: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    if [[ "$check_mode" == "true" ]]; then
        _cmd_migrate_check "$embed_dim"
        return $?
    fi
    if [[ "$embed_dim" -eq 384 ]]; then
        echo "-- [warn] embed_dim defaults to 384."
        echo "--        If your embedder outputs a different dimension (e.g. bge-m3 = 1024),"
        echo "--        re-run with: memo migrate --embed-dim N"
        echo "--"
    fi
    _cmd_migrate_sql | sed "s/vector(384)/vector(${embed_dim})/g"
}

