# memo sense — record reinforcements from relayed conversation turns (Phase 9).
# stdin: a JSON ARRAY of {role,text} turns (oldest first). The agent relays these
# since luamemo can't read the chat. Heuristics always run; --generative also runs
# the in-process instruct model (needs MEMO_GEN_MODEL + LuaJIT). Idempotent.
cmd_sense() {
    require_jq
    local scope="${MEMO_SCOPE:-}"
    local generative=false
    local extra='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope)          scope="$2"; shift 2 ;;
            --generative)     generative=true; shift ;;
            --min-similarity) extra=$(printf '%s' "$extra" | jq --argjson v "$2" '. + {min_similarity: $v}'); shift 2 ;;
            *) echo "memo sense: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    if [[ -z "$scope" ]]; then
        echo "memo sense: --scope required (or set MEMO_SCOPE)" >&2; exit 1
    fi
    local turns; turns=$(cat); [[ -z "$turns" ]] && turns='[]'
    printf '%s' "$turns" \
        | jq --arg s "$scope" --argjson g "$generative" --argjson e "$extra" \
             '{scope: $s, turns: ., generative: $g} + $e' \
        | api_call sense | jq .
}

