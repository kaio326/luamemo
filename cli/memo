#!/usr/bin/env bash
# memo — CLI wrapper for luamemo HTTP API.
#
# Configuration (env vars or ~/.memorc):
#   MEMO_URL    Base URL of the memory API, e.g. https://app.example.com/api/memory
#   MEMO_TOKEN  Bearer token sent as Authorization header (optional)
#
# Usage:
#   memo write   --scope SCOPE --kind KIND --title T --body B [--tags a,b,c]
#   memo search  QUERY [--scope SCOPE] [--kind KIND] [--limit N] [--since ISO|EPOCH] [--until ISO|EPOCH]
#   memo recent  [--scope SCOPE] [--limit N]
#   memo get     ID
#   memo update  ID [--title T] [--body B] [--scope S] [--kind K] [--tags a,b]
#   memo delete  ID
#   memo summarize [--scope S] [--dry-run] [--weight-threshold F] [--retention-days N]
#   memo promote --from FROM_SCOPE --to TO_SCOPE [--delete-source] [--dry-run] [--limit N]
#   memo secret-store  NAME [--desc DESCRIPTION] [--file PATH]
#   memo secret-list
#   memo secret-delete NAME
#   memo migrate         Print all luamemo migration SQL to stdout (pipe to psql)
#   memo init    [--non-interactive] [--multilingual] [--long] [--hosted] [--allow-hash] [--write PATH] [--root DIR]
#   memo doctor  [--setup PATH] [--json]

set -euo pipefail

# Load ~/.memorc if present (simple KEY=VALUE format).
if [[ -f "$HOME/.memorc" ]]; then
    # shellcheck disable=SC1091
    source "$HOME/.memorc"
fi

# shellcheck disable=SC2034
MEMO_URL_REQUIRED_DEFAULT=true
if [[ -n "${MEMO_URL:-}" ]]; then
    : # already set
fi
TOKEN_HEADER=()
if [[ -n "${MEMO_TOKEN:-}" ]]; then
    TOKEN_HEADER=(-H "Authorization: Bearer ${MEMO_TOKEN}")
fi

require_jq() {
    if ! command -v jq >/dev/null; then
        echo "memo: 'jq' is required but not installed" >&2
        exit 1
    fi
}

# Build a JSON body from --key value pairs. --tags is split on commas.
build_json() {
    local json='{}'
    while [[ $# -gt 0 ]]; do
        local key="${1#--}"
        local val="$2"
        if [[ "$key" == "tags" ]]; then
            local arr; arr=$(printf '%s' "$val" | jq -R 'split(",")|map(gsub("^\\s+|\\s+$";""))')
            json=$(printf '%s' "$json" | jq --argjson v "$arr" '. + {tags: $v}')
        else
            json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
        fi
        shift 2
    done
    printf '%s' "$json"
}

cmd_write() {
    require_jq
    local body; body=$(build_json "$@")
    curl -sS -X POST "${MEMO_URL}/write" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$body" | jq .
}

cmd_search() {
    require_jq
    local q="$1"; shift
    local args=(--data-urlencode "q=$q")
    while [[ $# -gt 0 ]]; do
        args+=(--data-urlencode "${1#--}=$2"); shift 2
    done
    curl -sS -G "${MEMO_URL}/search" "${TOKEN_HEADER[@]}" "${args[@]}" | jq .
}

cmd_recent() {
    require_jq
    local args=()
    while [[ $# -gt 0 ]]; do
        args+=(--data-urlencode "${1#--}=$2"); shift 2
    done
    curl -sS -G "${MEMO_URL}/recent" "${TOKEN_HEADER[@]}" "${args[@]}" | jq .
}

cmd_get() {
    require_jq
    curl -sS "${MEMO_URL}/$1" "${TOKEN_HEADER[@]}" | jq .
}

cmd_update() {
    require_jq
    local id="$1"; shift
    local body; body=$(build_json "$@")
    curl -sS -X POST "${MEMO_URL}/${id}/update" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$body" | jq .
}

cmd_delete() {
    require_jq
    curl -sS -X POST "${MEMO_URL}/$1/delete" "${TOKEN_HEADER[@]}" | jq .
}

cmd_summarize() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                json=$(printf '%s' "$json" | jq '. + {dry_run: true}')
                shift
                ;;
            --*)
                local key="${1#--}"; key="${key//-/_}"
                local val="$2"
                json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
                shift 2
                ;;
            *)
                echo "memo summarize: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    curl -sS -X POST "${MEMO_URL}/summarize" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$json" | jq .
}

# ---------------------------------------------------------------------------
# Secrets subcommands
# ---------------------------------------------------------------------------
# SECURITY: secret-store reads the value from --file or a no-echo stdin
# prompt. The value NEVER appears in shell arguments or chat context.
# ---------------------------------------------------------------------------

cmd_secret_store() {
    require_jq
    local name=""
    local desc=""
    local file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --desc)  desc="$2";  shift 2 ;;
            --file)  file="$2";  shift 2 ;;
            -*)  echo "memo secret-store: unknown flag: $1" >&2; exit 1 ;;
            *)   name="$1"; shift ;;
        esac
    done
    if [[ -z "$name" ]]; then
        echo "Usage: memo secret-store NAME [--desc DESCRIPTION] [--file PATH]" >&2
        exit 1
    fi
    local value
    if [[ -n "$file" ]]; then
        value=$(cat "$file")
    else
        # Read without echo so the value never appears on screen or in logs.
        read -r -s -p "Secret value for \"${name}\": " value
        echo >&2  # newline after the hidden input
    fi
    if [[ -z "$value" ]]; then
        echo "memo secret-store: value cannot be empty" >&2
        exit 1
    fi
    local body; body=$(jq -n \
        --arg n "$name" \
        --arg v "$value" \
        --arg d "$desc" \
        '{name: $n, value: $v, description: (if $d == "" then null else $d end)}')
    # Zero the shell variable immediately after JSON encoding.
    value=""
    curl -sS -X POST "${MEMO_URL}/secrets" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$body" | jq '{ok, secret: {id: .secret.id, name: .secret.name, description: .secret.description}}'
}

cmd_secret_list() {
    require_jq
    curl -sS "${MEMO_URL}/secrets" "${TOKEN_HEADER[@]}" \
        | jq '[.secrets[] | {id, name, description, used_count, last_used_at, updated_at}]'
}

cmd_secret_delete() {
    require_jq
    if [[ -z "${1:-}" ]]; then
        echo "Usage: memo secret-delete NAME" >&2; exit 1
    fi
    curl -sS -X POST "${MEMO_URL}/secrets/$1/delete" "${TOKEN_HEADER[@]}" | jq .
}

# ---------------------------------------------------------------------------
# memo migrate -- print all luamemo schema+migration SQL to stdout.
#
# Output is fully idempotent (IF NOT EXISTS / ADD COLUMN IF NOT EXISTS).
# Pipe to psql to apply:
#   memo migrate | psql -U postgres -d mydb
#   memo migrate | docker exec -i mydb psql -U postgres -d mydb
# ---------------------------------------------------------------------------
cmd_migrate() {
    cat <<'MIGRATE_EOF'
-- ==========================================================================
-- luamemo: full schema + migrations (generated by `memo migrate`)
-- All statements are idempotent -- safe to run on a fresh or existing DB.
-- ==========================================================================

-- migration 001 / schema ---------------------------------------------------

CREATE EXTENSION IF NOT EXISTS vector;

CREATE TABLE IF NOT EXISTS lapis_memory (
    id          BIGSERIAL PRIMARY KEY,
    scope       TEXT NOT NULL,
    kind        TEXT NOT NULL,
    title       TEXT NOT NULL,
    body        TEXT NOT NULL,
    tags        TEXT[] NOT NULL DEFAULT '{}',
    metadata    JSONB  NOT NULL DEFAULT '{}'::jsonb,
    embedding   vector(384),
    importance  REAL   NOT NULL DEFAULT 1.0
                    CHECK (importance >= 0.0 AND importance <= 10.0),
    decay_rate  REAL   NOT NULL DEFAULT 0.0
                    CHECK (decay_rate >= 0.0 AND decay_rate <= 1.0),
    was_truncated BOOLEAN NOT NULL DEFAULT FALSE,
    fts         tsvector GENERATED ALWAYS AS
                    (to_tsvector('english',
                        coalesce(title, '') || ' ' || coalesce(body, '')))
                STORED,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS lapis_memory_scope_idx ON lapis_memory (scope);
CREATE INDEX IF NOT EXISTS lapis_memory_kind_idx  ON lapis_memory (kind);
CREATE INDEX IF NOT EXISTS lapis_memory_tags_idx  ON lapis_memory USING GIN (tags);
CREATE INDEX IF NOT EXISTS lapis_memory_fts_idx   ON lapis_memory USING GIN (fts);
CREATE INDEX IF NOT EXISTS lapis_memory_embedding_hnsw_idx
    ON lapis_memory USING hnsw (embedding vector_cosine_ops);
CREATE INDEX IF NOT EXISTS lapis_memory_was_truncated_idx
    ON lapis_memory (was_truncated) WHERE was_truncated = TRUE;

CREATE OR REPLACE FUNCTION lapis_memory_touch_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = now();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS lapis_memory_touch_updated_at_trg ON lapis_memory;
CREATE TRIGGER lapis_memory_touch_updated_at_trg
    BEFORE UPDATE ON lapis_memory
    FOR EACH ROW
    EXECUTE FUNCTION lapis_memory_touch_updated_at();

-- migration 002 / importance + decay ---------------------------------------

ALTER TABLE lapis_memory ADD COLUMN IF NOT EXISTS importance  REAL NOT NULL DEFAULT 1.0;
ALTER TABLE lapis_memory ADD COLUMN IF NOT EXISTS decay_rate  REAL NOT NULL DEFAULT 0.0;

ALTER TABLE lapis_memory DROP CONSTRAINT IF EXISTS lapis_memory_importance_range;
ALTER TABLE lapis_memory ADD  CONSTRAINT lapis_memory_importance_range
    CHECK (importance >= 0.0 AND importance <= 10.0);

ALTER TABLE lapis_memory DROP CONSTRAINT IF EXISTS lapis_memory_decay_rate_range;
ALTER TABLE lapis_memory ADD  CONSTRAINT lapis_memory_decay_rate_range
    CHECK (decay_rate >= 0.0 AND decay_rate <= 1.0);

-- migration 003 / knowledge-graph layer ------------------------------------

CREATE TABLE IF NOT EXISTS lm_kg_facts (
    id               BIGSERIAL PRIMARY KEY,
    scope            TEXT        NOT NULL,
    subject          TEXT        NOT NULL,
    predicate        TEXT        NOT NULL,
    object           TEXT        NOT NULL,
    valid_from       TIMESTAMPTZ NOT NULL DEFAULT now(),
    valid_until      TIMESTAMPTZ,
    source_memory_id BIGINT      REFERENCES lapis_memory(id) ON DELETE SET NULL,
    created_at       TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS lm_kg_facts_scope_idx   ON lm_kg_facts (scope);
CREATE INDEX IF NOT EXISTS lm_kg_facts_sp_idx       ON lm_kg_facts (subject, predicate);
CREATE INDEX IF NOT EXISTS lm_kg_facts_current_idx  ON lm_kg_facts (subject, predicate)
    WHERE valid_until IS NULL;

ALTER TABLE lm_kg_facts DROP CONSTRAINT IF EXISTS lm_kg_facts_validity_window;
ALTER TABLE lm_kg_facts ADD  CONSTRAINT lm_kg_facts_validity_window
    CHECK (valid_until IS NULL OR valid_until >= valid_from);

-- migration 004 / was_truncated flag ---------------------------------------

ALTER TABLE lapis_memory ADD COLUMN IF NOT EXISTS was_truncated BOOLEAN NOT NULL DEFAULT FALSE;
MIGRATE_EOF
}

cmd_promote() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                json=$(printf '%s' "$json" | jq '. + {dry_run: true}')
                shift
                ;;
            --delete-source)
                json=$(printf '%s' "$json" | jq '. + {delete_source: true}')
                shift
                ;;
            --from)
                json=$(printf '%s' "$json" | jq --arg v "$2" '. + {from_scope: $v}')
                shift 2
                ;;
            --to)
                json=$(printf '%s' "$json" | jq --arg v "$2" '. + {to_scope: $v}')
                shift 2
                ;;
            --*)
                local key="${1#--}"; key="${key//-/_}"
                local val="$2"
                json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
                shift 2
                ;;
            *)
                echo "memo promote: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    curl -sS -X POST "${MEMO_URL}/promote" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$json" | jq .
}

# Find a Lua interpreter for local subcommands (init, doctor) that bypass
# the HTTP API and load the library modules directly.
find_lua() {
    for cand in lua5.1 luajit lua5.3 lua5.4 lua; do
        if command -v "$cand" >/dev/null; then echo "$cand"; return 0; fi
    done
    return 1
}

cmd_local_lua() {
    local module="$1"; shift
    local lua
    if ! lua=$(find_lua); then
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    fi
    # Build a Lua array literal of string args. Each arg goes inside
    # Lua long-bracket quotes ([==[...]==]) so embedded special chars
    # (quotes, backslashes, brackets) do not need escaping.
    local args=""
    for a in "$@"; do
        args+="[==[${a}]==],"
    done
    "$lua" -e "require('lapis_memory.cli.${module}').run({${args}})"
}

usage() {
    sed -n '2,17p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
}

[[ $# -lt 1 ]] && usage
sub="$1"; shift

# init/doctor/migrate are local subcommands and don't use MEMO_URL.
case "$sub" in
    init|doctor|migrate) ;;
    *) : "${MEMO_URL:?MEMO_URL is not set}" ;;
esac

case "$sub" in
    write)  cmd_write  "$@" ;;
    search) cmd_search "$@" ;;
    recent) cmd_recent "$@" ;;
    get)    cmd_get    "$@" ;;
    update) cmd_update "$@" ;;
    delete) cmd_delete "$@" ;;
    summarize) cmd_summarize "$@" ;;
    promote) cmd_promote "$@" ;;
    secret-store)  cmd_secret_store  "$@" ;;
    secret-list)   cmd_secret_list        ;;
    secret-delete) cmd_secret_delete "$@" ;;
    migrate) cmd_migrate ;;
    init)    cmd_local_lua init   "$@" ;;
    doctor)  cmd_local_lua doctor "$@" ;;
    -h|--help|help) usage ;;
    *) echo "memo: unknown subcommand: $sub" >&2; usage ;;
esac
