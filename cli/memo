# Used by --docker-compose FILE flag in cmd_calibrate.
# Parses a docker-compose.yml for Postgres credentials and host port,
# then exports MEMO_DB_URL.
# ---------------------------------------------------------------------------
_parse_compose_pg() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "memo calibrate: --docker-compose: file not found: $file" >&2
        return 1
    fi

    local pg_user="" pg_pass="" pg_db="" pg_port=""
    local in_pg_service=false in_environment=false

    while IFS= read -r line; do
        # Detect a service whose image contains "postgres"
        if [[ "$line" =~ ^[[:space:]]+image:[[:space:]].*postgres ]]; then
            in_pg_service=true
            in_environment=false
        fi
        # Detect a new 2-indent service name line (reset if leaving pg service)
        if [[ "$in_pg_service" == true ]] && \
           [[ "$line" =~ ^[[:space:]]{2}[a-zA-Z][a-zA-Z0-9_-]*:[[:space:]]*$ ]]; then
            # Only reset if we've already entered the pg service block
            # (any new 2-space service after the pg one ends its scope)
            in_pg_service=false
            in_environment=false
        fi
        if [[ "$in_pg_service" == true ]]; then
            # Begin of environment: block
            if [[ "$line" =~ ^[[:space:]]+environment:[[:space:]]*$ ]]; then
                in_environment=true
                continue
            fi
            # End of environment: section when another key at the same indent level appears
            if [[ "$in_environment" == true ]] && \
               [[ "$line" =~ ^[[:space:]]{4}[a-zA-Z] ]] && \
               ! [[ "$line" =~ POSTGRES_ ]]; then
                in_environment=false
            fi
            if [[ "$in_environment" == true ]]; then
                # Support both "  - KEY=VALUE" list form and "KEY: VALUE" map form
                local stripped="${line#"${line%%[! ]*}"}"   # ltrim
                if [[ "$stripped" =~ ^-[[:space:]]POSTGRES_USER=(.*)$ ]]; then
                    pg_user="${BASH_REMATCH[1]}"
                elif [[ "$stripped" =~ ^POSTGRES_USER:[[:space:]]*(.*)$ ]]; then
                    pg_user="${BASH_REMATCH[1]}"
                fi
                if [[ "$stripped" =~ ^-[[:space:]]POSTGRES_PASSWORD=(.*)$ ]]; then
                    pg_pass="${BASH_REMATCH[1]}"
                elif [[ "$stripped" =~ ^POSTGRES_PASSWORD:[[:space:]]*(.*)$ ]]; then
                    pg_pass="${BASH_REMATCH[1]}"
                fi
                if [[ "$stripped" =~ ^-[[:space:]]POSTGRES_DB=(.*)$ ]]; then
                    pg_db="${BASH_REMATCH[1]}"
                elif [[ "$stripped" =~ ^POSTGRES_DB:[[:space:]]*(.*)$ ]]; then
                    pg_db="${BASH_REMATCH[1]}"
                fi
            fi
            # ports: "HOST_PORT:5432"
            if [[ "$line" =~ ([0-9]+):5432 ]]; then
                pg_port="${BASH_REMATCH[1]}"
            fi
        fi
    done < "$file"

    pg_user="${pg_user:-postgres}"
    pg_db="${pg_db:-luamemo}"
    pg_port="${pg_port:-5432}"

    if [[ -z "$pg_pass" ]]; then
        echo "memo calibrate: --docker-compose: POSTGRES_PASSWORD not found in $file" >&2
        echo "  Set MEMO_DB_URL manually or add POSTGRES_PASSWORD to the Compose file." >&2
        return 1
    fi

    export MEMO_DB_URL="postgresql://${pg_user}:${pg_pass}@localhost:${pg_port}/${pg_db}"
    echo "  Docker Compose: detected Postgres → MEMO_DB_URL=${MEMO_DB_URL//:${pg_pass}@/:***@}"
}

# ---------------------------------------------------------------------------
# Write or replace a KEY=VALUE line in a config file.
# Creates the file if it does not exist.  If the key already exists it is
# replaced in-place so the file never accumulates duplicate entries.
# ---------------------------------------------------------------------------
_save_rc_key() {
    local file="$1" key="$2" value="$3"
    if [[ -f "$file" ]] && grep -q "^${key}=" "$file"; then
        local tmp; tmp=$(mktemp "${file}.XXXXXX")
        grep -v "^${key}=" "$file" > "$tmp" || true
        printf '%s=%s\n' "$key" "$value" >> "$tmp"
        mv "$tmp" "$file"
    else
        [[ ! -f "$file" ]] && (umask 177 && touch "$file")
        printf '%s=%s\n' "$key" "$value" >> "$file"
    fi
}

# Write key=value only when the key is not already present in the file.
# Used for probe-recommended embedder vars: on first run they are written from
# the system recommendation; on subsequent runs the user's values are preserved.
_save_rc_key_if_absent() {
    local file="$1" key="$2" value="$3"
    [[ -f "$file" ]] && grep -q "^${key}=" "$file" && return 0
    [[ ! -f "$file" ]] && (umask 177 && touch "$file")
    printf '%s=%s\n' "$key" "$value" >> "$file"
}

# Save MEMO_DB_URL to .luamemorc and print the standard credential tip.
_save_db_url_rc() {
    _save_rc_key "$PWD/.luamemorc" "MEMO_DB_URL" "$1"
    echo "  Saved to .luamemorc — future runs in this directory use this database."
    echo "  Tip: add .luamemorc to .gitignore if the URL contains credentials."
}

# ---------------------------------------------------------------------------
# memo setup — create SETUP_CHECK for first-run agent-guided verification.
# ---------------------------------------------------------------------------
cmd_setup() {
    local root="." force=false
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root)  root="$2"; shift 2 ;;
            --force) force=true; shift ;;
            *) echo "memo setup: unknown arg: $1" >&2; exit 1 ;;
        esac
    done

    local target; target="${root}/SETUP_CHECK"

    [[ -d "$root" ]] || { echo "memo setup: directory not found: $root" >&2; exit 1; }
    if [[ -f "$target" ]] && [[ "$force" != true ]]; then
        echo "memo setup: $target already exists (use --force to overwrite)." >&2
        echo "  If you are an AI agent, run \`memo calibrate\` to complete setup" >&2
        echo "  and remove the file automatically." >&2
        exit 1
    fi

    cat > "$target" << 'SETUP_EOF'
luamemo — First-Run Setup Verification
=======================================
This file was created by `memo setup`. It will be deleted automatically
when `memo calibrate` completes successfully. Do not commit this file.

If you are an AI agent, complete these steps in order:

  1. Verify database connectivity and table presence:

         memo ping

     Expected output: three green checks (DB, table, embedder).
     If the embedder check fails, that is non-fatal — DB and table are required.

  2. Apply schema migrations if the table is missing (idempotent):

         memo migrate | psql "$MEMO_DB_URL"

     Skip this step if `memo ping` reported the table as present.
     `memo calibrate` will also offer to run migrations automatically.

  3. Run the full setup (host probe, schema validation, codebase ingest,
     IDE/MCP config detection):

         memo calibrate --scope <your-project-scope>

     Replace <your-project-scope> with a short identifier for this project
     (e.g. "myapp" or "repo:myproject"). All ingested memories are tagged
     with this scope so they do not pollute unrelated projects.

  4. Confirm success:
     `memo calibrate` will print "First-run complete: SETUP_CHECK removed."
     and delete this file. If the file is still present, calibrate did not
     finish cleanly — check the output for errors and re-run.

If calibrate fails at any step, fix the reported error and run it again.
The file will not be deleted until calibrate exits successfully.
SETUP_EOF

    echo "Created: $target"
    echo "  Run \`memo calibrate\` to complete setup and remove the file."
    if [[ -e "${root}/.git" ]]; then
        local gitignore="${root}/.gitignore"
        if [[ -f "$gitignore" ]] && grep -qF 'SETUP_CHECK' "$gitignore" 2>/dev/null; then
            : # already ignored
        else
            echo "  Tip: add SETUP_CHECK to your .gitignore so it is not committed."
        fi
    fi
}

# memo calibrate — three-phase host probe, corpus health check, codebase ingest.
# ---------------------------------------------------------------------------
cmd_calibrate() {
    local root="." scope="" dry_run=false no_git=false no_comments=false probe_only=false
    local no_migrate=false no_mcp=false no_plugin=false dc_file="" keep_embedder=false
    local lua_extra_flags=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -h|--help)
                cat <<'EOF'
Usage: memo calibrate [OPTIONS]

Probe the environment, configure luamemo, and write .vscode/mcp.json.

Options:
  --scope SCOPE         Memory scope for calibration (default: repo:<basename>)
  --root DIR            Project root directory (default: .)
  --no-mcp              Skip writing .vscode/mcp.json
  --no-plugin           Skip installing the VS Code agent plugin
  --keep-embedder       Do not overwrite existing embedder config in .luamemorc
  --probe-only          Run host probe only; skip codebase ingest
  --no-migrate          Skip applying DB migrations
  --no-git              Skip git-history scan
  --no-comments         Skip code comment extraction
  --docker-compose FILE Parse DB credentials from a docker-compose file
  --dry-run             Show what would be written without writing
  --multilingual        Include non-Lua source files in scan
  --long                Allow longer memory bodies
  --hosted              Optimise for hosted (non-local) embedder
  --allow-hash          Allow hash embedder (normally skipped in calibrate)
  --write PATH          Write scan output to a file instead of DB
  -h, --help            Show this help and exit
EOF
                exit 0
                ;;
            --root)        root="$2";        shift 2 ;;
            --scope)       scope="$2";       shift 2 ;;
            --dry-run)     dry_run=true;     shift   ;;
            --no-git)      no_git=true;      shift   ;;
            --no-comments) no_comments=true; shift   ;;
            --probe-only)  probe_only=true;  shift   ;;
            --no-migrate)  no_migrate=true;  shift   ;;
            --no-mcp)      no_mcp=true;      shift   ;;
            --no-plugin)   no_plugin=true;   shift   ;;
            --keep-embedder) keep_embedder=true; shift ;;
            --docker-compose) dc_file="$2";  shift 2 ;;
            --non-interactive|--multilingual|--long|--hosted|--allow-hash)
                lua_extra_flags+="[==[${1}]==],"; shift ;;
            --write)
                lua_extra_flags+="[==[--write]==],[==[${2}]==],"; shift 2 ;;
            *) echo "memo calibrate: unknown arg: $1" >&2; exit 1 ;;
        esac
    done

    local lua; lua=$(find_lua) || {
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    }

    # ── Phase 1: host probe + embedder recommendation (no DB required) ──────
    # Apply --docker-compose credentials before probe so they're visible in output.
    if [[ -n "$dc_file" ]]; then
        _parse_compose_pg "$dc_file" || true
        if [[ -n "${MEMO_DB_URL:-}" ]]; then
            _save_db_url_rc "$MEMO_DB_URL"
        fi
    fi

    # Run probe. Write config snippet to a temp file so we can extract embed_dim
    # and pass it to cmd_migrate later (avoids vector(384) hardcode mismatch).
    local _probe_tmp; _probe_tmp=$(mktemp /tmp/luamemo_probe_XXXXXX.lua)
    "$lua" -e "require('luamemo.cli.calibrate').run({[==[--root]==],[==[${root}]==],${lua_extra_flags}[==[--write]==],[==[${_probe_tmp}]==]})"
    local _probe_embed_dim=384
    local _probe_eadp="" _probe_eurl="" _probe_emdl="" _probe_emxc=""
    if [[ -s "$_probe_tmp" ]]; then
        local _awk_out
        _awk_out=$(awk '
            /embed_dim[[:space:]]*=[[:space:]]*[0-9]/{match($0,/[0-9]+/);dim=substr($0,RSTART,RLENGTH)}
            /embedder_local[[:space:]]*=/{match($0,/"[^"]*"/);loc=substr($0,RSTART+1,RLENGTH-2)}
            /embedder_adapter[[:space:]]*=/{match($0,/"[^"]*"/);adp=substr($0,RSTART+1,RLENGTH-2)}
            /embedder_url[[:space:]]*=/{match($0,/"[^"]*"/);url=substr($0,RSTART+1,RLENGTH-2)}
            /embedder_model[[:space:]]*=/{match($0,/"[^"]*"/);mdl=substr($0,RSTART+1,RLENGTH-2)}
            /embed_max_chars[[:space:]]*=[[:space:]]*[0-9]/{match($0,/[0-9]+/);mxc=substr($0,RSTART,RLENGTH)}
            END{printf "%s\t%s\t%s\t%s\t%s\t%s\n",dim,loc,adp,url,mdl,mxc}
        ' "$_probe_tmp")
        IFS=$'\t' read -r _probe_embed_dim _probe_eloc _probe_eadp _probe_eurl _probe_emdl _probe_emxc <<< "$_awk_out"
        [[ -n "$_probe_embed_dim" ]] || _probe_embed_dim=384
    fi
    rm -f "$_probe_tmp"
    # Persist probe-recommended embedder config to .luamemorc if DB is already
    # set (guard: don't create a partial config before DB is configured).
    # Use "write if absent" semantics so that existing user-configured values
    # (e.g. a host-side MEMO_EMBEDDER_URL set by a prior docker-compose detect)
    # are never clobbered by the probe, which just echoes back whatever URL was
    # already in the environment.
    # --keep-embedder skips this block entirely so users can re-run calibrate
    # without touching their working embedder config.
    if [[ "$keep_embedder" != true ]] && [[ -n "${MEMO_DB_URL:-}" ]]; then
        # Embedder-switch warning: two different embedders' vectors are NEVER
        # comparable, even at the same embed_dim — existing rows silently lose
        # vector-search relevance until re-embedded (FTS still works, which is
        # exactly why this is easy to miss). Two ways this happens even under
        # write-if-absent semantics below: (a) the embedder actually changed
        # from what .luamemorc already had, or (b) this is a FRESH .luamemorc
        # (no local prior value to compare) pointed at a database that already
        # has rows for this scope — e.g. a fresh clone / a different host
        # connecting to a shared DB. Best-effort: skipped silently if psql
        # isn't available.
        local _old_eloc="" _old_emdl=""
        if [[ -f "$PWD/.luamemorc" ]]; then
            _old_eloc=$(grep -E '^MEMO_EMBEDDER=' "$PWD/.luamemorc" 2>/dev/null | tail -1 | cut -d= -f2-) || true
            _old_emdl=$(grep -E '^MEMO_EMBEDDER_MODEL=' "$PWD/.luamemorc" 2>/dev/null | tail -1 | cut -d= -f2-) || true
        fi
        local _embedder_changed=false
        if [[ -n "$_old_eloc" && -n "$_probe_eloc" && "$_old_eloc" != "$_probe_eloc" ]]; then
            _embedder_changed=true
        elif [[ -n "$_old_emdl" && -n "$_probe_emdl" && "$_old_emdl" != "$_probe_emdl" ]]; then
            _embedder_changed=true
        fi

        if command -v psql >/dev/null 2>&1; then
            local _target_scope="${scope:-repo:$(basename "$(cd "$root" 2>/dev/null && pwd)")}"
            local _existing_rows
            _existing_rows=$(PGPASSWORD="${PGPASSWORD:-}" psql "$MEMO_DB_URL" -tA \
                -v target_scope="$_target_scope" 2>/dev/null <<'SQL' || echo ""
SELECT count(*) FROM lm_memories WHERE scope = :'target_scope';
SQL
)
            if [[ "$_existing_rows" =~ ^[0-9]+$ ]] && [[ "$_existing_rows" -gt 0 ]]; then
                if [[ "$_embedder_changed" == true ]]; then
                    echo ""
                    echo "  WARNING: embedder is changing (${_old_eloc:-$_old_emdl} -> ${_probe_eloc:-$_probe_emdl})."
                    echo "  ${_existing_rows} existing memories in scope '${_target_scope}' were embedded with"
                    echo "  the PREVIOUS model — a different model's vectors are never comparable, even at the"
                    echo "  same dimension, so vector search relevance will silently degrade on those rows"
                    echo "  until they are re-embedded. Run:  memo reembed --scope ${_target_scope}"
                elif [[ -z "$_old_eloc" ]]; then
                    echo ""
                    echo "  NOTE: scope '${_target_scope}' already has ${_existing_rows} memories, but no local"
                    echo "  embedder config was found (e.g. a fresh clone connecting to a shared database)."
                    echo "  If those rows were embedded with a DIFFERENT model than the one being configured"
                    echo "  now, vector search relevance will be degraded until they are re-embedded. Run:"
                    echo "    memo reembed --scope ${_target_scope}"
                fi
            fi
        fi

        # Local embedder selector (hash / gguf_ffi / …). For gguf_ffi the user
        # also sets MEMO_GGUF_MODEL after downloading the model (see the guide
        # printed by `memo calibrate`).
        [[ -n "$_probe_eloc" ]] && _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_EMBEDDER" "$_probe_eloc"
        [[ -n "$_probe_eadp" ]] && _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_EMBEDDER_ADAPTER" "$_probe_eadp"
        [[ -n "$_probe_eurl" ]] && _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_EMBEDDER_URL"     "$_probe_eurl"
        [[ -n "$_probe_emdl" ]] && _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_EMBEDDER_MODEL"   "$_probe_emdl"
        _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_EMBED_DIM" "$_probe_embed_dim"
        [[ -n "$_probe_emxc" ]] && _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_EMBED_MAX_CHARS"  "$_probe_emxc"
        # Self-maintaining memory: a debounced digest piggybacks on writes so tier
        # promotion / consolidation / decay run without any agent or scheduler
        # having to call `memo digest`. Write-if-absent, so an explicit 0 is kept.
        _save_rc_key_if_absent "$PWD/.luamemorc" "MEMO_AUTO_DIGEST" "1"
    fi
    [[ "$probe_only" == true ]] && return 0

    # ── Phase 2: resolve DB connection ──────────────────────────────────────
    # Resolution order (first match wins):
    #   1. $PWD/.luamemorc exists → project already configured, use its URL
    #   2. $MEMO_DB_URL already set by --docker-compose or explicit env export
    #   3. $DATABASE_URL env var (common 12-factor / Heroku convention)
    #   4. $POSTGRES_DB + sibling POSTGRES_*/PG* env vars → build MEMO_DB_URL
    #   5. $PGDATABASE + $PGHOST env vars → build MEMO_DB_URL
    #   6. Auto-detect docker-compose.yml / docker-compose.yaml in CWD
    #   7. Prompt once, save to .luamemorc

    # If no project-local .luamemorc exists yet, do not silently reuse a
    # MEMO_DB_URL that was inherited from another project's global ~/.memorc.
    if [[ ! -f "$PWD/.luamemorc" && "${_MEMO_CONFIG_SOURCE:-}" == "global" ]]; then
        echo "  Note: MEMO_DB_URL is currently set from ~/.memorc (may belong to another project)."
        echo "  Running DB detection for this project..."
        unset MEMO_DB_URL
    fi

    if [[ -z "${MEMO_DB_URL:-}" ]]; then
        if [[ -n "${DATABASE_URL:-}" ]]; then
            export MEMO_DB_URL="$DATABASE_URL"
            echo "  DB: using DATABASE_URL"
            _save_db_url_rc "$MEMO_DB_URL"
        elif [[ -n "${POSTGRES_DB:-}" ]]; then
            local _pg_user="${POSTGRES_USER:-${PGUSER:-postgres}}"
            local _pg_pass="${POSTGRES_PASSWORD:-${PGPASSWORD:-}}"
            local _pg_host="${POSTGRES_HOST:-${PGHOST:-127.0.0.1}}"
            local _pg_port="${POSTGRES_PORT:-${PGPORT:-5432}}"
            local _url
            if _url=$(_build_pg_url "$_pg_user" "$_pg_pass" "$_pg_host" "$_pg_port" "${POSTGRES_DB}"); then
                export MEMO_DB_URL="$_url"
                echo "  DB: assembled from POSTGRES_* env vars → ${POSTGRES_DB}"
                _save_db_url_rc "$MEMO_DB_URL"
            else
                echo "  Falling back to manual MEMO_DB_URL prompt."
            fi
        elif [[ -n "${PGDATABASE:-}" ]]; then
            local _pg_user="${PGUSER:-postgres}"
            local _pg_pass="${PGPASSWORD:-}"
            local _pg_host="${PGHOST:-127.0.0.1}"
            local _pg_port="${PGPORT:-5432}"
            local _url
            if _url=$(_build_pg_url "$_pg_user" "$_pg_pass" "$_pg_host" "$_pg_port" "${PGDATABASE}"); then
                export MEMO_DB_URL="$_url"
                echo "  DB: assembled from PG* env vars → ${PGDATABASE}"
                _save_db_url_rc "$MEMO_DB_URL"
            else
                echo "  Falling back to manual MEMO_DB_URL prompt."
            fi
        elif [[ -f "docker-compose.yml" ]] || [[ -f "docker-compose.yaml" ]]; then
            local _dc="docker-compose.yml"
            [[ -f "docker-compose.yaml" ]] && _dc="docker-compose.yaml"
            echo "  DB: auto-detected $_dc — probing for Postgres config..."
            _parse_compose_pg "$_dc" || true
            if [[ -n "${MEMO_DB_URL:-}" ]]; then
                _save_db_url_rc "$MEMO_DB_URL"
            fi
        fi
    fi

    if [[ -z "${MEMO_DB_URL:-}" ]]; then
        echo ""
        echo "  No database config found."
        if [[ -t 0 ]]; then
            echo -n "  Enter MEMO_DB_URL (e.g. postgresql://postgres:@127.0.0.1:5432/luamemo): "
            read -r MEMO_DB_URL
        else
            echo "  (non-interactive: skipping prompt — set MEMO_DB_URL before running calibrate)"
            MEMO_DB_URL=""
        fi
        if [[ -z "$MEMO_DB_URL" ]]; then
            echo ""
            echo "  No database configured — memories will NOT be saved."
            echo "     Re-run: memo calibrate"
            return 0
        fi
        echo ""
        _save_db_url_rc "$MEMO_DB_URL"
        export MEMO_DB_URL
    fi

    # ── Phase 2.5: schema check ─────────────────────────────────────────────
    # Query information_schema to verify lm_memories and lm_kg_facts exist
    # and carry all expected columns.  If anything is missing, offer to apply
    # the full schema automatically (requires psql on PATH).
    if [[ "${no_migrate:-false}" != "true" ]]; then
        echo ""
        echo "Checking schema..."

        local schema_result
        schema_result=$(printf '{}' | api_call schema-check 2>/dev/null || echo '{"ok":false,"db_error":"api call failed"}')

        local schema_ok
        schema_ok=$(printf '%s' "$schema_result" | jq -r '.ok // false' 2>/dev/null || echo "false")

        if [[ "$schema_ok" == "true" ]]; then
            echo "  Schema: OK"
        else
            # Collect details: which tables are missing or have missing columns.
            local mem_present mem_missing kg_present kg_missing
            mem_present=$(printf '%s' "$schema_result" | jq -r '.tables.lm_memories.present // false' 2>/dev/null || echo "false")
            mem_missing=$(printf '%s' "$schema_result" | jq -r '(.tables.lm_memories.missing_cols // []) | join(", ")' 2>/dev/null || echo "")
            kg_present=$(printf '%s' "$schema_result" | jq -r '.tables.lm_kg_facts.present // false' 2>/dev/null || echo "false")
            kg_missing=$(printf '%s' "$schema_result" | jq -r '(.tables.lm_kg_facts.missing_cols // []) | join(", ")' 2>/dev/null || echo "")

            # Check for a DB connection error — this is distinct from "table missing":
            # if the Lua process couldn't connect at all, the schema-check result
            # contains db_error on every table entry.  Treat this as a connectivity
            # problem, not a missing-schema problem, so we don't confusingly say
            # "table missing" and then have psql succeed (contradicting the check).
            local any_db_err
            any_db_err=$(printf '%s' "$schema_result" | \
                jq -r '[.tables // {} | to_entries[] | .value.db_error // empty] | first // ""' \
                2>/dev/null || echo "")
            if [[ -n "$any_db_err" ]]; then
                echo "  Schema check: DB connection failed — cannot verify schema."
                echo "    Error: $any_db_err"
                echo "    Verify MEMO_DB_URL ($(_redact_url "${MEMO_DB_URL:-}")) is reachable, then re-run."
                echo "  (If the schema already exists this is harmless once connectivity is restored.)"
                return 0
            fi

            echo "  Schema: incomplete"
            [[ "$mem_present" != "true" ]] && echo "    - lm_memories table: missing"
            [[ "$mem_present" == "true" ]] && [[ -n "$mem_missing" ]] && echo "    - lm_memories columns missing: $mem_missing"
            [[ "$kg_present" != "true" ]] && echo "    - lm_kg_facts table: missing"
            [[ "$kg_present" == "true" ]] && [[ -n "$kg_missing" ]] && echo "    - lm_kg_facts columns missing: $kg_missing"
            echo ""

            local do_migrate="n"
            if command -v psql >/dev/null 2>&1; then
                _confirm_yn "Apply schema now?" && do_migrate="y"
            else
                echo "  psql not found — cannot apply schema automatically."
            fi

            if [[ "$do_migrate" =~ ^[Yy]$ ]]; then
                echo "  Applying schema (embed_dim=${_probe_embed_dim})..."
                if cmd_migrate --embed-dim "${_probe_embed_dim}" | PGPASSWORD="${PGPASSWORD:-}" psql "$MEMO_DB_URL" -v ON_ERROR_STOP=1 -q; then
                    echo "  Schema applied successfully."
                else
                    echo ""
                    echo "  ERROR: psql exited with an error. Check the output above." >&2
                    echo "  You can apply the schema manually:" >&2
                    echo "    memo migrate --embed-dim ${_probe_embed_dim} | psql \"\$MEMO_DB_URL\"" >&2
                    echo "  Codebase ingest will be skipped until the schema is ready." >&2
                    return 1
                fi
            else
                echo ""
                echo "  Schema not applied. Memories cannot be stored without it."
                echo "  To apply manually:"
                echo "    memo migrate --embed-dim ${_probe_embed_dim} | psql \"$MEMO_DB_URL\""
                echo ""
                echo "  Without the schema, codebase ingest will fail."
                echo "  Re-run memo calibrate once the schema is in place."
                return 0
            fi
        fi
    fi

    # ── Phase 3: auto-detect scope ──────────────────────────────────────────
    if [[ -z "$scope" ]]; then
        if [[ -n "${MEMO_SCOPE:-}" ]]; then
            scope="$MEMO_SCOPE"
        else
            local remote; remote=$(git -C "$root" remote get-url origin 2>/dev/null || echo "")
            if [[ -n "$remote" ]]; then
                scope="repo:$(basename "$remote" .git)"
            else
                scope="repo:$(basename "$(cd "$root" && pwd)")"
            fi
        fi
    fi

    echo ""
    echo "Ingesting codebase → scope: $scope"

    # Get last calibrated commit for incremental scanning (via KG)
    local since_sha=""
    since_sha=$(jq -n \
        --arg scope "$scope" \
        '{scope: $scope, subject: "calibrate", predicate: "last_commit", limit: 1}' \
        | api_call kg-query \
        | jq -r '(.results // []) | if type=="array" then .[0] else ."1" end | .object // empty' \
        2>/dev/null || echo "")
    [[ -n "$since_sha" ]] && echo "  (incremental: commits since ${since_sha:0:7})"

    # Build Lua flags for the scan phase
    local scan_flags="[==[--scan]==],[==[--scope]==],[==[${scope}]==],[==[--root]==],[==[${root}]==],"
    [[ -n "$since_sha" ]] && scan_flags+="[==[--since-commit]==],[==[${since_sha}]==],"
    [[ "$no_git" == true      ]] && scan_flags+="[==[--no-git]==],"
    [[ "$no_comments" == true ]] && scan_flags+="[==[--no-comments]==],"

    # ── Phase 4: scan → write (single Lua process handles all writes) ────────
    local count=0 errors=0
    if [[ "$dry_run" == true ]]; then
        while IFS= read -r mem_line; do
            [[ -z "$mem_line" ]] && continue
            local title; title=$(printf '%s' "$mem_line" | jq -r '.title // "(no title)"' 2>/dev/null)
            echo "  [dry-run] $title"
            (( count++ )) || true
        done < <("$lua" -e "require('luamemo.cli.calibrate').run({${scan_flags}})")
        echo ""
        echo "  [dry-run] Would write $count memories. Re-run without --dry-run to apply."
    else
        while IFS= read -r result_line; do
            [[ -z "$result_line" ]] && continue
            local ok; ok=$(printf '%s' "$result_line" | jq -r '.ok // false' 2>/dev/null)
            if [[ "$ok" == "true" ]]; then
                (( count++ )) || true
            else
                (( errors++ )) || true
            fi
        done < <(
            "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.calibrate').run({${scan_flags}})" \
            | "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.api').dispatch('write-many')"
        )
        echo ""
        echo "  Done: $count memories written ($errors errors) to scope=$scope"
    fi

    # Update KG cursor so next calibrate only processes new commits
    if [[ "$dry_run" != true ]] && [[ "$no_git" != true ]]; then
        local head_sha; head_sha=$(git -C "$root" rev-parse HEAD 2>/dev/null || echo "")
        if [[ -n "$head_sha" ]]; then
            jq -n \
                --arg scope "$scope" \
                --arg sha "$head_sha" \
                '{scope: $scope, subject: "calibrate", predicate: "last_commit", object: $sha, supersede: true}' \
            | api_call kg-assert >/dev/null 2>&1 || true
        fi
    fi

    # ── Phase 5: IDE detection + MCP config ─────────────────────────────────
    if [[ "${no_mcp:-false}" != "true" ]]; then
        _calibrate_mcp_phase "$root" "$scope"
    fi

    # ── Phase 6: VS Code agent plugin install ────────────────────────────────
    if [[ "${no_plugin:-false}" != "true" ]]; then
        _calibrate_plugin_phase
    fi

    # ── Cleanup: remove SETUP_CHECK on successful first-run ──────────────────
    if [[ "$dry_run" != true ]] && [[ -f "${root}/SETUP_CHECK" ]]; then
        rm -f "${root}/SETUP_CHECK"
        echo ""
        echo "  First-run complete: SETUP_CHECK removed."
    fi
}

# ---------------------------------------------------------------------------
# VS Code agent plugin installer (called from cmd_calibrate phase 6)
# ---------------------------------------------------------------------------

# Echoes both the stable and Insiders plugin directories (one per line).
# Calling uname once and building both paths avoids two subshell forks.
_plugin_dirs() {
    local _os; _os="$(uname -s 2>/dev/null)"
    local _base
    if [[ "$_os" == "Darwin" ]]; then
        _base="$HOME/Library/Application Support"
    else
        _base="${XDG_CONFIG_HOME:-$HOME/.config}"
    fi
    echo "$_base/Code/agentPlugins/github.com/kaio326/luamemo"
    echo "$_base/Code - Insiders/agentPlugins/github.com/kaio326/luamemo"
}

# Prints the manual-install instructions; shared by two branches below.
_plugin_manual_msg() {
    echo "  To install manually: in VS Code Chat run 'Chat: Install Plugin From Source'"
    echo "  URL: https://github.com/kaio326/luamemo"
}

_calibrate_plugin_phase() {
    if ! command -v git &>/dev/null; then
        echo "  [plugin] git not found — skipping plugin install."
        _plugin_manual_msg; return
    fi

    local _installed=false
    local _dir
    while IFS= read -r _dir; do
        # Guard against empty path (e.g. $HOME unset in some containers).
        [[ -n "$_dir" ]] || continue

        # Skip if the VS Code agentPlugins parent directory doesn't exist.
        # On headless servers without VS Code this will always be absent.
        local _parent; _parent="$(dirname "$(dirname "$(dirname "$_dir")")")" 
        [[ -d "$_parent" ]] || continue

        if [[ -d "$_dir/.git" ]]; then
            # Skip the network pull if the plugin was fetched less than 24 h ago.
            # Clamp _age to 999999 on clock skew (negative result) to force pull.
            local _fetch_head="$_dir/.git/FETCH_HEAD"
            local _age=999999
            if [[ -f "$_fetch_head" ]]; then
                local _now _mtime
                _now=$(date +%s 2>/dev/null) || _now=0
                _mtime=$(date -r "$_fetch_head" +%s 2>/dev/null) || _mtime=0
                _age=$(( _now - _mtime ))
                (( _age < 0 )) && _age=999999
            fi
            if (( _age < 86400 )); then
                echo "  [plugin] Plugin is current (last checked < 24h ago)."
            else
                echo "  [plugin] Updating plugin at ${_dir} ..."
                git -C "$_dir" pull --ff-only --quiet 2>/dev/null \
                    && echo "  [plugin] Plugin up to date." \
                    || echo "  [plugin] Update skipped (local changes or no network)."
            fi
        else
            echo "  [plugin] Installing luamemo VS Code plugin ..."
            mkdir -p "$(dirname "$_dir")"
            git clone --depth 1 --quiet \
                https://github.com/kaio326/luamemo "$_dir" 2>/dev/null \
                && echo "  [plugin] Installed. Reload VS Code (Developer: Reload Window) to activate." \
                || echo "  [plugin] Clone failed — check network or install manually via 'Chat: Install Plugin From Source'."
        fi
        _installed=true
    done < <(_plugin_dirs)

    if [[ "$_installed" == false ]]; then
        echo "  [plugin] VS Code not detected — skipping plugin install."
        _plugin_manual_msg
    else
        echo "  Tip: add \"chat.mcp.autoStart\": true to VS Code settings so the"
        echo "       MCP server starts automatically when VS Code opens."
    fi
}

# _confirm_yn <prompt> — prints "<prompt> [y/N] ", reads an answer, returns
# 0 (true) for y/Y, 1 (false) otherwise. Under `set -e`, a bare `read` with
# no data available on stdin (a script, CI, or an agent's shell tool — no
# TTY) fails and silently kills the whole calibrate run with no error message
# and no clue why; guard with a TTY check and treat non-interactive as "no",
# printing a note so the skip is visible instead of a silent, unexplained
# truncation of the run.
_confirm_yn() {
    echo -n "  $1 [y/N] "
    if [[ ! -t 0 ]]; then
        echo "(non-interactive: skipping)"
        return 1
    fi
    local ans; read -r ans
    [[ "$ans" =~ ^[Yy]$ ]]
}

# ---------------------------------------------------------------------------
# IDE detection + MCP config writer (called from cmd_calibrate phase 5)
# ---------------------------------------------------------------------------
_calibrate_mcp_phase() {
    local root="$1" scope="$2"

    local lua_bin; lua_bin=$(find_lua) || lua_bin="lua"
    # The in-process GGUF embedder (embedder_local=gguf_ffi) needs LuaJIT (FFI),
    # so the MCP server must launch under `luajit`, not lua5.1. Detect the chosen
    # embedder from the env or the persisted .luamemorc.
    local _mcp_embedder="${MEMO_EMBEDDER:-}"
    if [[ -z "$_mcp_embedder" && -f "$PWD/.luamemorc" ]]; then
        _mcp_embedder=$(grep -E '^MEMO_EMBEDDER=' "$PWD/.luamemorc" 2>/dev/null | tail -1 | cut -d= -f2-)
    fi
    if [[ "$_mcp_embedder" == "gguf_ffi" ]]; then
        if command -v luajit >/dev/null 2>&1; then
            lua_bin="luajit"
            echo "  (embedder is gguf_ffi → MCP server will launch under luajit for FFI)"
        else
            echo "  WARNING: embedder=gguf_ffi needs luajit but it was not found;" >&2
            echo "           MCP server will use $lua_bin and in-process embedding will fail." >&2
        fi
    fi
    local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # Resolve absolute path to mcp/server.lua.
    # When installed via LuaRocks, this script lands in a bin/ directory and
    # the naive "${script_dir}/../mcp/server.lua" resolves to a non-existent
    # path.  We try four strategies in order:
    #   1. Relative to this script (works in git-repo / dev mode).
    #   2. luarocks show — asks the installed package manager for the prefix.
    #   3. find in common LuaRocks tree roots (slow but reliable fallback).
    #   4. Keep the relative path and warn the user to fix it manually.
    local mcp_server=""
    local _rel="${script_dir}/../mcp/server.lua"
    if [[ -f "$_rel" ]]; then
        command -v realpath >/dev/null 2>&1 \
            && mcp_server=$(realpath "$_rel" 2>/dev/null) \
            || mcp_server="$_rel"
    fi

    if [[ -z "$mcp_server" ]]; then
        # Strategy 2: ask luarocks for the install prefix.
        local _lr_prefix=""
        for _lr in luarocks-5.1 luarocks; do
            if command -v "$_lr" >/dev/null 2>&1; then
                _lr_prefix=$("$_lr" show luamemo 2>/dev/null \
                    | grep -i "installed in:" | head -1 \
                    | sed 's/.*[Ii]nstalled in:[[:space:]]*//')
                [[ -n "$_lr_prefix" ]] && break
            fi
        done
        if [[ -n "$_lr_prefix" ]]; then
            local _srv
            _srv=$(find "$_lr_prefix/lib/luarocks" \
                -path "*/luamemo/*/mcp/server.lua" 2>/dev/null | sort -V | tail -1)
            [[ -n "$_srv" ]] && mcp_server="$_srv"
        fi
    fi

    if [[ -z "$mcp_server" ]]; then
        # Strategy 3: search common LuaRocks tree roots.
        local _srv
        for _prefix in "${HOME}/.luarocks" "/usr/local" "/usr"; do
            if [[ -d "${_prefix}/lib/luarocks" ]]; then
                _srv=$(find "${_prefix}/lib/luarocks" -maxdepth 8 \
                    -path "*/luamemo/*/mcp/server.lua" 2>/dev/null | sort -V | tail -1)
                if [[ -n "$_srv" ]]; then
                    mcp_server="$_srv"
                    break
                fi
            fi
        done
    fi

    # Strategy 4: fall back to the relative path; warn below if it doesn't exist.
    [[ -z "$mcp_server" ]] && mcp_server="$_rel"

    # Block if the server file still can't be found — writing a broken path
    # into the MCP client config causes silent failures that are hard to debug.
    if [[ ! -f "$mcp_server" ]]; then
        echo ""
        echo "  WARNING: mcp/server.lua not found at:"
        echo "    $mcp_server"
        if [[ -t 0 ]]; then
            echo -n "  Enter the correct path to mcp/server.lua (or press Enter to skip MCP config): "
            local _user_path; read -r _user_path
            if [[ -z "$_user_path" ]]; then
                echo "  Skipping MCP config write (no valid server path)."
                echo "  To configure manually, set 'args' in your MCP client config to"
                echo "  the path of mcp/server.lua from the luamemo LuaRocks installation."
                return 0
            elif [[ -f "$_user_path" ]]; then
                mcp_server="$_user_path"
            else
                echo "  Path does not exist: $_user_path"
                echo "  Skipping MCP config write."
                return 0
            fi
        else
            echo "  Non-interactive: skipping MCP config write."
            echo "  Typical location: <luarocks-prefix>/lib/luarocks/rocks-5.1/luamemo/<ver>/mcp/server.lua"
            return 0
        fi
    fi

    local db_url="${MEMO_DB_URL:-}"

    # Derive a per-project MCP entry name so multiple projects can coexist in
    # global Cursor / Claude Desktop configs without overwriting each other.
    # With a scope set (e.g. "myapp") the key becomes "luamemo-myapp"; without
    # a scope it falls back to plain "luamemo" for backward compatibility.
    local mcp_key="luamemo"
    if [[ -n "${scope:-}" ]]; then
        local _safe; _safe=$(printf '%s' "$scope" | tr '[:upper:]' '[:lower:]' | tr -cs 'a-z0-9' '-' | sed 's/^-*//;s/-*$//')
        [[ -n "$_safe" ]] && mcp_key="luamemo-${_safe}"
    fi

    # Warn if the URL is empty — a blank MEMO_DB_URL in the generated config
    # causes the MCP server to silently fail to connect on first use.
    if [[ -z "$db_url" ]]; then
        echo ""
        echo "  WARNING: MEMO_DB_URL is not set."
        echo "  The generated MCP config will have an empty MEMO_DB_URL and the"
        echo "  MCP server will fail to connect to Postgres."
        echo "  Set MEMO_DB_URL before running memo calibrate, or edit the"
        echo "  env.MEMO_DB_URL field in the generated config manually."
        echo "  Example: export MEMO_DB_URL=postgresql://user:pass@localhost:5432/luamemo"
    fi

    # Build the MCP server env block (JSON).
    # Embedder env vars are included only when set so the MCP server config
    # mirrors exactly what the shell environment provides.
    local mcp_env
    mcp_env=$(jq -n \
        --arg db   "$db_url" \
        --arg sc   "$scope" \
        --arg eurl "${MEMO_EMBEDDER_URL:-}" \
        --arg eadp "${MEMO_EMBEDDER_ADAPTER:-}" \
        --arg emdl "${MEMO_EMBEDDER_MODEL:-}" \
        --arg edim "${MEMO_EMBED_DIM:-}" \
        --arg eloc "${_mcp_embedder:-}" \
        --arg gmdl "${MEMO_GGUF_MODEL:-}" \
        '{"MEMO_DB_URL": $db, "MEMO_SCOPE": $sc}
         | if $eurl != "" then . + {"MEMO_EMBEDDER_URL": $eurl} else . end
         | if $eadp != "" then . + {"MEMO_EMBEDDER_ADAPTER": $eadp} else . end
         | if $emdl != "" then . + {"MEMO_EMBEDDER_MODEL": $emdl} else . end
         | if $edim != "" then . + {"MEMO_EMBED_DIM": $edim} else . end
         | if $eurl == "" and $eloc != "" then . + {"MEMO_EMBEDDER": $eloc} else . end
         | if $gmdl != "" then . + {"MEMO_GGUF_MODEL": $gmdl} else . end')

    # Build the VS Code / Claude Desktop / Cursor MCP entry (JSON).
    local vscode_entry
    vscode_entry=$(jq -n \
        --arg cmd "$lua_bin" \
        --arg srv "$mcp_server" \
        --argjson env "$mcp_env" \
        '{"type":"stdio","command":$cmd,"args":[$srv],"env":$env}')

    local claude_entry
    claude_entry=$(jq -n \
        --arg cmd "$lua_bin" \
        --arg srv "$mcp_server" \
        --argjson env "$mcp_env" \
        '{"command":$cmd,"args":[$srv],"env":$env}')

    echo ""
    echo "MCP client configuration"
    echo "========================"

    # ── VS Code (.vscode/mcp.json) ───────────────────────────────────────
    local vscode_dir="${root}/.vscode"
    local vscode_mcp="${vscode_dir}/mcp.json"
    local has_vscode=false
    [[ -d "$vscode_dir" ]] && has_vscode=true

    if [[ "$has_vscode" == "true" ]]; then
        echo "  Detected: VS Code workspace (.vscode/ found)"
        if [[ -f "$vscode_mcp" ]]; then
            # Check if a luamemo entry already exists under this key.
            local already
            already=$(jq -r --arg key "$mcp_key" '.servers[$key] // empty' "$vscode_mcp" 2>/dev/null || echo "")
            if [[ -n "$already" ]]; then
                echo "  .vscode/mcp.json: ${mcp_key} entry already present — skipping."
            else
                if _confirm_yn "Write ${mcp_key} MCP entry to .vscode/mcp.json?"; then
                    local updated
                    updated=$(jq --arg key "$mcp_key" --argjson entry "$vscode_entry" '.servers[$key] = $entry' "$vscode_mcp")
                    printf '%s\n' "$updated" > "$vscode_mcp"
                    echo "  Updated: $vscode_mcp"
                fi
            fi
        else
            if _confirm_yn "Create .vscode/mcp.json with ${mcp_key} entry?"; then
                mkdir -p "$vscode_dir"
                jq -n --arg key "$mcp_key" --argjson entry "$vscode_entry" '{"servers":{($key):$entry}}' > "$vscode_mcp"
                echo "  Created: $vscode_mcp"
            fi
        fi
    fi

    # ── Cursor (~/.cursor/mcp.json) ──────────────────────────────────────
    local cursor_mcp="${HOME}/.cursor/mcp.json"
    if [[ -d "${HOME}/.cursor" ]]; then
        echo "  Detected: Cursor (~/.cursor/ found)"
        if [[ -f "$cursor_mcp" ]]; then
            local already
            already=$(jq -r --arg key "$mcp_key" '.mcpServers[$key] // empty' "$cursor_mcp" 2>/dev/null || echo "")
            if [[ -n "$already" ]]; then
                echo "  ~/.cursor/mcp.json: ${mcp_key} entry already present — skipping."
            else
                if _confirm_yn "Write ${mcp_key} MCP entry to ~/.cursor/mcp.json?"; then
                    local updated
                    updated=$(jq --arg key "$mcp_key" --argjson entry "$claude_entry" '.mcpServers[$key] = $entry' "$cursor_mcp")
                    printf '%s\n' "$updated" > "$cursor_mcp"
                    echo "  Updated: $cursor_mcp"
                fi
            fi
        else
            if _confirm_yn "Create ~/.cursor/mcp.json with ${mcp_key} entry?"; then
                jq -n --arg key "$mcp_key" --argjson entry "$claude_entry" '{"mcpServers":{($key):$entry}}' > "$cursor_mcp"
                echo "  Created: $cursor_mcp"
            fi
        fi
    fi

    # ── Claude Desktop ───────────────────────────────────────────────────
    local claude_cfg=""
    if [[ "$(uname)" == "Darwin" ]]; then
        claude_cfg="${HOME}/Library/Application Support/Claude/claude_desktop_config.json"
    else
        claude_cfg="${HOME}/.config/Claude/claude_desktop_config.json"
    fi
    if [[ -f "$claude_cfg" ]]; then
        echo "  Detected: Claude Desktop (${claude_cfg})"
        local already
        already=$(jq -r --arg key "$mcp_key" '.mcpServers[$key] // empty' "$claude_cfg" 2>/dev/null || echo "")
        if [[ -n "$already" ]]; then
            echo "  claude_desktop_config.json: ${mcp_key} entry already present — skipping."
        else
            if _confirm_yn "Write ${mcp_key} MCP entry to Claude Desktop config?"; then
                local updated
                updated=$(jq --arg key "$mcp_key" --argjson entry "$claude_entry" '.mcpServers[$key] = $entry' "$claude_cfg")
                printf '%s\n' "$updated" > "$claude_cfg"
                echo "  Updated: $claude_cfg"
            fi
        fi
    fi

    # ── Nothing detected — print manual instructions ─────────────────────
    if [[ "$has_vscode" != "true" ]] && [[ ! -d "${HOME}/.cursor" ]] && [[ ! -f "$claude_cfg" ]]; then
        echo "  No IDE config detected. Add this to your MCP client config manually:"
        echo ""
        echo "  VS Code (.vscode/mcp.json):"
        jq -n --arg key "$mcp_key" --argjson entry "$vscode_entry" '{"servers":{($key):$entry}}' | sed 's/^/    /'
        echo ""
        echo "  Claude Desktop / Cursor (mcpServers block):"
        jq -n --arg key "$mcp_key" --argjson entry "$claude_entry" '{"mcpServers":{($key):$entry}}' | sed 's/^/    /'
    fi

    echo ""
    echo "  Note: memory.setup() and routes.register() are only needed if your"
    echo "  application code calls store.write/search in-process, or you want"
    echo "  the /api/memory HTTP routes available to non-MCP clients."
    echo "  For Copilot Agent Mode, Cursor, or Claude Desktop using MEMO_DB_URL,"
    echo "  the MCP server above handles everything — no setup() call required."
    echo ""
    echo "  IMPORTANT — verify MEMO_DB_URL for your deployment environment:"
    echo "  The MCP server connects to Postgres using the MEMO_DB_URL value above."
    echo "  In Docker deployments 127.0.0.1 is the MCP client host, not the"
    echo "  container. Use the service name or a host-routable address instead,"
    echo "  e.g. postgresql://user:pass@db:5432/luamemo"
    echo "  Update the env.MEMO_DB_URL field in the generated config if needed."
    echo ""
}

# ---------------------------------------------------------------------------
# _cmd_doctor_check: standalone DB health check via psql.
# Requires only a DB URL. No Lua interpreter, no setup() context needed.
# Exits 0 if healthy, 1 if problems found.
# ---------------------------------------------------------------------------
_cmd_doctor_check() {
    local db_url="${1:-${MEMO_DB_URL:-}}"
    if [[ -z "$db_url" ]]; then
        echo "memo doctor --db-url: no DB URL provided and MEMO_DB_URL is not set." >&2
        echo "  Usage: memo doctor --db-url postgresql://user:pass@host:5432/dbname" >&2
        exit 1
    fi
    if ! command -v psql &>/dev/null; then
        echo "memo doctor --db-url: psql not found in PATH." >&2
        exit 1
    fi
    local all_ok=true

    # Run all diagnostic queries in one psql session — single connection and
    # auth handshake instead of 4 separate subprocesses.
    # Section markers (\echo MARKER) delimit output sections for bash parsing.
    local _psql_out
    if ! _psql_out=$(PGPASSWORD="${PGPASSWORD:-}" psql "$db_url" --no-psqlrc -At 2>&1 <<'DOCTOR_SQL'
\echo __LM_CONNECTED__
SELECT extname FROM pg_extension WHERE extname = 'vector';
\echo __LM_VEC_DONE__
SELECT column_name FROM information_schema.columns
WHERE  table_schema = 'public' AND table_name = 'lm_memories'
ORDER  BY column_name;
\echo __LM_COLS_DONE__
SELECT table_name FROM information_schema.tables
WHERE  table_schema = 'public' AND table_name = 'lm_kg_facts';
\echo __LM_KG_DONE__
DOCTOR_SQL
    ); then
        echo "DB connectivity..."
        echo "  ✗ cannot connect to $(_redact_url "$db_url")"
        exit 1
    fi
    echo "DB connectivity..."
    echo "  ✓ connected"

    # Extract each section: lines between marker pairs, markers excluded.
    local _vec_out _cols_out _kg_out
    _vec_out=$(printf   '%s\n' "$_psql_out" | awk '/^__LM_CONNECTED__/{f=1;next} /^__LM_VEC_DONE__/{f=0}   f')
    _cols_out=$(printf  '%s\n' "$_psql_out" | awk '/^__LM_VEC_DONE__/{f=1;next}  /^__LM_COLS_DONE__/{f=0}  f')
    _kg_out=$(printf    '%s\n' "$_psql_out" | awk '/^__LM_COLS_DONE__/{f=1;next} /^__LM_KG_DONE__/{f=0}    f')

    echo "pgvector extension..."
    if [[ "$_vec_out" == "vector" ]]; then
        echo "  ✓ vector extension installed"
    else
        echo "  ✗ vector extension missing (run: CREATE EXTENSION vector;)"
        all_ok=false
    fi

    echo "lm_memories schema..."
    if [[ -z "$_cols_out" ]]; then
        echo "  ✗ lm_memories table not found"
        echo "    Run: memo migrate | psql \"$(_redact_url "$db_url")\""
        all_ok=false
    else
        _check_col_list "$_cols_out" || all_ok=false
    fi

    echo ""
    echo "lm_kg_facts table..."
    if [[ -n "$_kg_out" ]]; then
        echo "  ✓ present"
    else
        echo "  ✗ missing (run: memo migrate | psql \"$(_redact_url "$db_url")\")"
        all_ok=false
    fi

    echo ""
    if [[ "$all_ok" == "true" ]]; then
        echo "All checks passed — database is healthy."
    else
        echo "Problems found. Run: memo migrate | psql \"$(_redact_url "$db_url")\""
        exit 1
    fi
}

# memo doctor [--db-url URL] [--setup PATH] [--json]
# --db-url URL: standalone mode (no Lua, no setup() context needed).
# Without --db-url: falls through to the Lua-based doctor.
cmd_doctor() {
    local db_url=""
    local passthrough_args=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --db-url) db_url="$2"; shift 2 ;;
            *) passthrough_args+=("$1"); shift ;;
        esac
    done
    if [[ -n "$db_url" ]]; then
        _cmd_doctor_check "$db_url"
        return $?
    fi
    cmd_local_lua doctor "${passthrough_args[@]}"
}

cmd_local_lua() {
    local module="$1"; shift
    local lua
    if ! lua=$(find_lua); then
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    fi
    local args=""
    for a in "$@"; do
        args+="[==[${a}]==],"
    done
    "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.${module}').run({${args}})"
}

usage() {
    awk 'NR>1 && /^[^#]/{exit} NR>1{sub(/^# ?/,""); print}' "$0"
    exit 0
}

[[ $# -lt 1 ]] && usage
sub="$1"; shift

case "$sub" in
    write)  cmd_write  "$@" ;;
    search) cmd_search "$@" ;;
    recent) cmd_recent "$@" ;;
    get)    cmd_get    "$@" ;;
    update) cmd_update "$@" ;;
    delete) cmd_delete "$@" ;;
    summarize) cmd_summarize "$@" ;;
    promote) cmd_promote "$@" ;;
    context) cmd_context "$@" ;;
    brief)  cmd_brief   "$@" ;;
    consolidate) cmd_consolidate "$@" ;;
    digest) cmd_digest "$@" ;;
    sense)  cmd_sense  "$@" ;;
    learn)  cmd_learn  "$@" ;;
    reembed) cmd_reembed "$@" ;;
    index)     cmd_local_lua index "$@" ;;
    calibrate) cmd_calibrate "$@" ;;
    setup)     cmd_setup     "$@" ;;
    secret-store)   cmd_secret_store   "$@" ;;
    secret-list)    cmd_secret_list         ;;
    secret-delete)  cmd_secret_delete  "$@" ;;
    secret-execute) cmd_secret_execute "$@" ;;
    migrate) cmd_migrate "$@" ;;
    ping)
        # Show which config file supplied MEMO_DB_URL so the user knows which
        # database will be checked — critical when multiple projects are present.
        case "${_MEMO_CONFIG_SOURCE:-}" in
            local)  echo "[INFO] config: $PWD/.luamemorc" ;;
            global) echo "[WARN] config: ~/.memorc (global — no .luamemorc in $PWD)" ;;
            *)      echo "[INFO] config: environment" ;;
        esac
        cmd_local_lua ping "$@" ;;
    doctor)  cmd_doctor            "$@" ;;
    -h|--help|help) usage ;;
    *) echo "memo: unknown subcommand: $sub" >&2; usage ;;
esac