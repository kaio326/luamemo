#!/usr/bin/env bash
# memo — CLI wrapper for luamemo HTTP API.
#
# Configuration (env vars or ~/.memorc):
#   MEMO_URL    Base URL of the memory API, e.g. https://app.example.com/api/memory
#   MEMO_TOKEN  Bearer token sent as Authorization header (optional)
#
# Usage:
#   memo write   --scope SCOPE --kind KIND --title T --body B [--tags a,b,c]
#   memo search  QUERY [--scope SCOPE] [--kind KIND] [--limit N] [--since ISO|EPOCH] [--until ISO|EPOCH]
#   memo recent  [--scope SCOPE] [--limit N]
#   memo get     ID
#   memo update  ID [--title T] [--body B] [--scope S] [--kind K] [--tags a,b]
#   memo delete  ID
#   memo summarize [--scope S] [--dry-run] [--weight-threshold F] [--retention-days N]
#   memo promote --from FROM_SCOPE --to TO_SCOPE [--delete-source] [--dry-run] [--limit N]
#   memo context QUERY [--scope SCOPE] [--limit N] [--no-kg] [--format text|json]
#   memo consolidate [--scope SCOPE] [--dry-run] [--similarity-threshold F]
#                    [--decay-threshold F] [--max-rows N]
#   memo calibrate [--scope SCOPE] [--root DIR] [--no-git] [--no-comments] [--dry-run]
#                  [--probe-only] [--multilingual] [--long] [--hosted] [--allow-hash]
#                  [--write PATH]
#   memo secret-store  NAME [--desc DESCRIPTION] [--file PATH]
#   memo secret-list
#   memo secret-delete NAME
#   memo secret-execute NAME URL [--method M] [--header K:V]... [--body TEXT]
#                               [--form FIELD=VALUE]... [--form-file FIELD:PATH]
#                               [--timeout-ms N]
#   memo migrate         Print all luamemo migration SQL to stdout (pipe to psql)
#   memo doctor  [--setup PATH] [--json]

set -euo pipefail

# Load ~/.memorc if present (simple KEY=VALUE format).
if [[ -f "$HOME/.memorc" ]]; then
    # shellcheck disable=SC1091
    source "$HOME/.memorc"
fi

# shellcheck disable=SC2034
MEMO_URL_REQUIRED_DEFAULT=true
if [[ -n "${MEMO_URL:-}" ]]; then
    : # already set
fi
TOKEN_HEADER=()
if [[ -n "${MEMO_TOKEN:-}" ]]; then
    TOKEN_HEADER=(-H "Authorization: Bearer ${MEMO_TOKEN}")
fi

require_jq() {
    if ! command -v jq >/dev/null; then
        echo "memo: 'jq' is required but not installed" >&2
        exit 1
    fi
}

# Build a JSON body from --key value pairs. --tags is split on commas.
build_json() {
    local json='{}'
    while [[ $# -gt 0 ]]; do
        local key="${1#--}"
        local val="$2"
        if [[ "$key" == "tags" ]]; then
            local arr; arr=$(printf '%s' "$val" | jq -R 'split(",")|map(gsub("^\\s+|\\s+$";""))')
            json=$(printf '%s' "$json" | jq --argjson v "$arr" '. + {tags: $v}')
        else
            json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
        fi
        shift 2
    done
    printf '%s' "$json"
}

cmd_write() {
    require_jq
    local body; body=$(build_json "$@")
    curl -sS -X POST "${MEMO_URL}/write" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$body" | jq .
}

cmd_search() {
    require_jq
    local q="$1"; shift
    local args=(--data-urlencode "q=$q")
    while [[ $# -gt 0 ]]; do
        args+=(--data-urlencode "${1#--}=$2"); shift 2
    done
    curl -sS -G "${MEMO_URL}/search" "${TOKEN_HEADER[@]}" "${args[@]}" | jq .
}

cmd_recent() {
    require_jq
    local args=()
    while [[ $# -gt 0 ]]; do
        args+=(--data-urlencode "${1#--}=$2"); shift 2
    done
    curl -sS -G "${MEMO_URL}/recent" "${TOKEN_HEADER[@]}" "${args[@]}" | jq .
}

cmd_get() {
    require_jq
    curl -sS "${MEMO_URL}/$1" "${TOKEN_HEADER[@]}" | jq .
}

cmd_update() {
    require_jq
    local id="$1"; shift
    local body; body=$(build_json "$@")
    curl -sS -X POST "${MEMO_URL}/${id}/update" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$body" | jq .
}

cmd_delete() {
    require_jq
    curl -sS -X POST "${MEMO_URL}/$1/delete" "${TOKEN_HEADER[@]}" | jq .
}

cmd_summarize() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                json=$(printf '%s' "$json" | jq '. + {dry_run: true}')
                shift
                ;;
            --*)
                local key="${1#--}"; key="${key//-/_}"
                local val="$2"
                json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
                shift 2
                ;;
            *)
                echo "memo summarize: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    curl -sS -X POST "${MEMO_URL}/summarize" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$json" | jq .
}

# ---------------------------------------------------------------------------
# Secrets subcommands
# ---------------------------------------------------------------------------
# SECURITY: secret-store reads the value from --file or a no-echo stdin
# prompt. The value NEVER appears in shell arguments or chat context.
# ---------------------------------------------------------------------------

cmd_secret_store() {
    require_jq
    local name=""
    local desc=""
    local file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --desc)  desc="$2";  shift 2 ;;
            --file)  file="$2";  shift 2 ;;
            -*)  echo "memo secret-store: unknown flag: $1" >&2; exit 1 ;;
            *)   name="$1"; shift ;;
        esac
    done
    if [[ -z "$name" ]]; then
        echo "Usage: memo secret-store NAME [--desc DESCRIPTION] [--file PATH]" >&2
        exit 1
    fi
    local value
    if [[ -n "$file" ]]; then
        value=$(cat "$file")
    else
        # Read without echo so the value never appears on screen or in logs.
        read -r -s -p "Secret value for \"${name}\": " value
        echo >&2  # newline after the hidden input
    fi
    if [[ -z "$value" ]]; then
        echo "memo secret-store: value cannot be empty" >&2
        exit 1
    fi
    local body; body=$(jq -n \
        --arg n "$name" \
        --arg v "$value" \
        --arg d "$desc" \
        '{name: $n, value: $v, description: (if $d == "" then null else $d end)}')
    # Zero the shell variable immediately after JSON encoding.
    value=""
    curl -sS -X POST "${MEMO_URL}/secrets" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$body" | jq '{ok, secret: {id: .secret.id, name: .secret.name, description: .secret.description}}'
}

cmd_secret_list() {
    require_jq
    curl -sS "${MEMO_URL}/secrets" "${TOKEN_HEADER[@]}" \
        | jq '[.secrets[] | {id, name, description, used_count, last_used_at, updated_at}]'
}

cmd_secret_delete() {
    require_jq
    if [[ -z "${1:-}" ]]; then
        echo "Usage: memo secret-delete NAME" >&2; exit 1
    fi
    curl -sS -X POST "${MEMO_URL}/secrets/$1/delete" "${TOKEN_HEADER[@]}" | jq .
}

cmd_secret_execute() {
    require_jq
    if [[ -z "${1:-}" ]] || [[ -z "${2:-}" ]]; then
        echo "Usage: memo secret-execute NAME URL [--method M] [--header K:V]..." >&2
        echo "                                   [--body TEXT]" >&2
        echo "                                   [--form FIELD=VALUE]..." >&2
        echo "                                   [--form-file FIELD:PATH]..." >&2
        echo "                                   [--timeout-ms N]" >&2
        exit 1
    fi
    local name="$1" url="$2"; shift 2
    local method= timeout_ms= body= headers='{}'
    local -a form_fields=()   # plain string fields
    local -a form_files=()    # file fields
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --method)     method="$2";     shift 2 ;;
            --timeout-ms) timeout_ms="$2"; shift 2 ;;
            --body)       body="$2";       shift 2 ;;
            --header)
                # K:V  — add to the headers JSON object
                local hkey="${2%%:*}" hval="${2#*:}"
                headers=$(printf '%s' "$headers" | jq --arg k "$hkey" --arg v "$hval" '. + {($k): $v}')
                shift 2 ;;
            --form)
                # FIELD=VALUE
                form_fields+=("$2"); shift 2 ;;
            --form-file)
                # FIELD:PATH
                form_files+=("$2"); shift 2 ;;
            *) echo "memo secret-execute: unknown flag: $1" >&2; exit 1 ;;
        esac
    done

    # Build the JSON payload.
    local payload; payload=$(jq -n --arg url "$url" '{url: $url}')
    [[ -n "$method"     ]] && payload=$(printf '%s' "$payload" | jq --arg v "$method"     '. + {method: $v}')
    [[ -n "$timeout_ms" ]] && payload=$(printf '%s' "$payload" | jq --argjson v "$timeout_ms" '. + {timeout_ms: $v}')
    [[ -n "$body"       ]] && payload=$(printf '%s' "$payload" | jq --arg v "$body"       '. + {body: $v}')
    if [[ "$headers" != "{}" ]]; then
        payload=$(printf '%s' "$payload" | jq --argjson v "$headers" '. + {headers: $v}')
    fi

    # Build multipart object when --form or --form-file flags are present.
    if [[ ${#form_fields[@]} -gt 0 ]] || [[ ${#form_files[@]} -gt 0 ]]; then
        local mp='{}'
        for kv in "${form_fields[@]}"; do
            local fk="${kv%%=*}" fv="${kv#*=}"
            mp=$(printf '%s' "$mp" | jq --arg k "$fk" --arg v "$fv" '. + {($k): $v}')
        done
        for kv in "${form_files[@]}"; do
            local fk="${kv%%:*}" fv="${kv#*:}"
            mp=$(printf '%s' "$mp" | jq --arg k "$fk" --arg v "$fv" '. + {($k): {file: $v}}')
        done
        payload=$(printf '%s' "$payload" | jq --argjson v "$mp" '. + {multipart: $v}')
    fi

    curl -sS -X POST "${MEMO_URL}/secrets/${name}/execute" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$payload" | jq .
}

# ---------------------------------------------------------------------------
# memo migrate -- print all luamemo schema+migration SQL to stdout.
#
# Output is fully idempotent (IF NOT EXISTS / ADD COLUMN IF NOT EXISTS).
# Pipe to psql to apply:
#   memo migrate | psql -U postgres -d mydb
#   memo migrate | docker exec -i mydb psql -U postgres -d mydb
# ---------------------------------------------------------------------------
cmd_migrate() {
    cat <<'MIGRATE_EOF'
-- ==========================================================================
-- luamemo: full schema + migrations (generated by `memo migrate`)
-- All statements are idempotent -- safe to run on a fresh or existing DB.
-- ==========================================================================

-- migration 001 / schema ---------------------------------------------------

CREATE EXTENSION IF NOT EXISTS vector;

CREATE TABLE IF NOT EXISTS lm_memories (
    id          BIGSERIAL PRIMARY KEY,
    scope       TEXT NOT NULL,
    kind        TEXT NOT NULL,
    title       TEXT NOT NULL,
    body        TEXT NOT NULL,
    tags        TEXT[] NOT NULL DEFAULT '{}',
    metadata    JSONB  NOT NULL DEFAULT '{}'::jsonb,
    embedding   vector(384),
    importance  REAL   NOT NULL DEFAULT 1.0
                    CHECK (importance >= 0.0 AND importance <= 10.0),
    decay_rate  REAL   NOT NULL DEFAULT 0.0
                    CHECK (decay_rate >= 0.0 AND decay_rate <= 1.0),
    was_truncated BOOLEAN NOT NULL DEFAULT FALSE,
    fts         tsvector GENERATED ALWAYS AS
                    (to_tsvector('english',
                        coalesce(title, '') || ' ' || coalesce(body, '')))
                STORED,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at  TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS lm_memories_scope_idx ON lm_memories (scope);
CREATE INDEX IF NOT EXISTS lm_memories_kind_idx  ON lm_memories (kind);
CREATE INDEX IF NOT EXISTS lm_memories_tags_idx  ON lm_memories USING GIN (tags);
CREATE INDEX IF NOT EXISTS lm_memories_fts_idx   ON lm_memories USING GIN (fts);
CREATE INDEX IF NOT EXISTS lm_memories_embedding_hnsw_idx
    ON lm_memories USING hnsw (embedding vector_cosine_ops);
CREATE INDEX IF NOT EXISTS lm_memories_was_truncated_idx
    ON lm_memories (was_truncated) WHERE lm_memories.was_truncated = TRUE;

CREATE OR REPLACE FUNCTION lm_memories_touch_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = now();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS lm_memories_touch_updated_at_trg ON lm_memories;
CREATE TRIGGER lm_memories_touch_updated_at_trg
    BEFORE UPDATE ON lm_memories
    FOR EACH ROW
    EXECUTE FUNCTION lm_memories_touch_updated_at();

-- migration 002 / importance + decay ---------------------------------------

ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS importance  REAL NOT NULL DEFAULT 1.0;
ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS decay_rate  REAL NOT NULL DEFAULT 0.0;

ALTER TABLE lm_memories DROP CONSTRAINT IF EXISTS lm_memories_importance_range;
ALTER TABLE lm_memories ADD  CONSTRAINT lm_memories_importance_range
    CHECK (importance >= 0.0 AND importance <= 10.0);

ALTER TABLE lm_memories DROP CONSTRAINT IF EXISTS lm_memories_decay_rate_range;
ALTER TABLE lm_memories ADD  CONSTRAINT lm_memories_decay_rate_range
    CHECK (decay_rate >= 0.0 AND decay_rate <= 1.0);

-- migration 003 / knowledge-graph layer ------------------------------------

CREATE TABLE IF NOT EXISTS lm_kg_facts (
    id               BIGSERIAL PRIMARY KEY,
    scope            TEXT        NOT NULL,
    subject          TEXT        NOT NULL,
    predicate        TEXT        NOT NULL,
    object           TEXT        NOT NULL,
    valid_from       TIMESTAMPTZ NOT NULL DEFAULT now(),
    valid_until      TIMESTAMPTZ,
    source_memory_id BIGINT      REFERENCES lm_memories(id) ON DELETE SET NULL,
    created_at       TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS lm_kg_facts_scope_idx   ON lm_kg_facts (scope);
CREATE INDEX IF NOT EXISTS lm_kg_facts_sp_idx       ON lm_kg_facts (subject, predicate);
CREATE INDEX IF NOT EXISTS lm_kg_facts_current_idx  ON lm_kg_facts (subject, predicate)
    WHERE valid_until IS NULL;

ALTER TABLE lm_kg_facts DROP CONSTRAINT IF EXISTS lm_kg_facts_validity_window;
ALTER TABLE lm_kg_facts ADD  CONSTRAINT lm_kg_facts_validity_window
    CHECK (valid_until IS NULL OR valid_until >= valid_from);

-- migration 004 / was_truncated flag ---------------------------------------

ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS was_truncated BOOLEAN NOT NULL DEFAULT FALSE;
MIGRATE_EOF
}

cmd_promote() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                json=$(printf '%s' "$json" | jq '. + {dry_run: true}')
                shift
                ;;
            --delete-source)
                json=$(printf '%s' "$json" | jq '. + {delete_source: true}')
                shift
                ;;
            --from)
                json=$(printf '%s' "$json" | jq --arg v "$2" '. + {from_scope: $v}')
                shift 2
                ;;
            --to)
                json=$(printf '%s' "$json" | jq --arg v "$2" '. + {to_scope: $v}')
                shift 2
                ;;
            --*)
                local key="${1#--}"; key="${key//-/_}"
                local val="$2"
                json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
                shift 2
                ;;
            *)
                echo "memo promote: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    curl -sS -X POST "${MEMO_URL}/promote" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$json" | jq .
}

# memo context QUERY [--scope SCOPE] [--limit N] [--no-kg] [--format text|json]
# Assembles a compact, prompt-injection-ready context block from search results
# and optional KG ground-truth facts. All processing is local — no cloud calls.
cmd_context() {
    require_jq
    local q="${1:-}"
    if [[ -z "$q" ]]; then
        echo "Usage: memo context QUERY [--scope SCOPE] [--limit N] [--no-kg] [--format text|json]" >&2
        exit 1
    fi
    shift

    local scope="" limit=10 no_kg=false format="text"
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --scope)  scope="$2";  shift 2 ;;
            --limit)  limit="$2";  shift 2 ;;
            --no-kg)  no_kg=true;  shift   ;;
            --format) format="$2"; shift 2 ;;
            *) echo "memo context: unknown arg: $1" >&2; exit 1 ;;
        esac
    done

    local search_args=(--data-urlencode "q=$q" --data-urlencode "limit=$limit")
    [[ -n "$scope" ]] && search_args+=(--data-urlencode "scope=$scope")

    local mem_json
    mem_json=$(curl -sS -G "${MEMO_URL}/search" "${TOKEN_HEADER[@]}" "${search_args[@]}")

    local kg_json=""
    if [[ "$no_kg" == "false" ]] && [[ -n "$scope" ]]; then
        kg_json=$(curl -sS -G "${MEMO_URL}/kg/query" "${TOKEN_HEADER[@]}" \
            --data-urlencode "scope=$scope" \
            --data-urlencode "limit=20" 2>/dev/null) || kg_json='{"ok":false}'
    fi

    if [[ "$format" == "json" ]]; then
        jq -n \
            --argjson mem "$mem_json" \
            --argjson kg "${kg_json:-null}" \
            '{memories: ($mem.results // []), kg_facts: (if $kg then ($kg.results // []) else [] end)}'
        return
    fi

    # Text format: compact, prompt-injection-ready block.
    echo "=== MEMORY CONTEXT ==="
    [[ -n "$scope" ]] && echo "scope: $scope"
    echo "query: \"$q\""
    echo ""

    local mem_list
    mem_list=$(printf '%s' "$mem_json" | jq -r '
        (.results // []) |
        if type == "array" then . else [.[]] end |
        to_entries[] |
        "[" + ((.key + 1) | tostring) + "] " + (.value.kind // "?") +
        " \u2014 " + (.value.title // "") + "\n" + (.value.body // "") + "\n"
    ' 2>/dev/null)

    if [[ -n "$mem_list" ]]; then
        echo "$mem_list"
    else
        echo "(no memories found)"
        echo ""
    fi

    if [[ -n "$kg_json" ]] && [[ "$kg_json" != '{"ok":false}' ]]; then
        local facts
        facts=$(printf '%s' "$kg_json" | jq -r '
            (.results // []) |
            if type == "array" then . else [.[]] end |
            .[] |
            "\u2022 " + .subject + " " + .predicate + " " + .object
        ' 2>/dev/null)
        if [[ -n "$facts" ]]; then
            echo "=== GROUND TRUTH (knowledge graph) ==="
            echo "$facts"
            echo ""
        fi
    fi

    echo "=== END CONTEXT ==="
}

# memo consolidate [--scope SCOPE] [--dry-run] [--similarity-threshold F]
#                  [--decay-threshold F] [--max-rows N]
cmd_consolidate() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                json=$(printf '%s' "$json" | jq '. + {dry_run: true}')
                shift
                ;;
            --*)
                local key="${1#--}"; key="${key//-/_}"
                local val="$2"
                json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
                shift 2
                ;;
            *) echo "memo consolidate: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    curl -sS -X POST "${MEMO_URL}/consolidate" \
        "${TOKEN_HEADER[@]}" \
        -H "Content-Type: application/json" \
        -d "$json" | jq .
}

# memo calibrate — three-phase host probe, corpus health check, and codebase ingest.
# Probe phase runs without MEMO_URL. Ingest phase requires a running API.
cmd_calibrate() {
    require_jq
    local root="." scope="" dry_run=false no_git=false no_comments=false probe_only=false
    local lua_extra_flags=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root)        root="$2";        shift 2 ;;
            --scope)       scope="$2";       shift 2 ;;
            --dry-run)     dry_run=true;     shift   ;;
            --no-git)      no_git=true;      shift   ;;
            --no-comments) no_comments=true; shift   ;;
            --probe-only)  probe_only=true;  shift   ;;
            --non-interactive|--multilingual|--long|--hosted|--allow-hash)
                lua_extra_flags+="[==[${1}]==],"; shift ;;
            --write)
                lua_extra_flags+="[==[--write]==],[==[${2}]==],"; shift 2 ;;
            *) echo "memo calibrate: unknown arg: $1" >&2; exit 1 ;;
        esac
    done

    local lua; lua=$(find_lua) || {
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    }

    # ── Phase 1: host probe + embedder recommendation (no server required) ──
    "$lua" -e "require('luamemo.cli.calibrate').run({[==[--root]==],[==[${root}]==],${lua_extra_flags}})"
    [[ "$probe_only" == true ]] && return 0

    # ── Phases 2+3: resolve MEMO_URL ────────────────────────────────────────
    # Resolution order:
    #   1. --url flag or $MEMO_URL env var (already in env from ~/.memorc load)
    #   2. Auto-probe localhost:8765 (standard luamemo Docker Compose port)
    #   3. Prompt once, save to ~/.memorc

    local _auto_token_generated=false

    if [[ -z "${MEMO_URL:-}" ]]; then
        # Try the standard local dev port silently
        local _probe_url="http://localhost:8765/api/memory"
        if curl -sf --connect-timeout 1 "${_probe_url}/recent?limit=1" \
                ${TOKEN_HEADER[@]+"${TOKEN_HEADER[@]}"} -o /dev/null 2>/dev/null; then
            MEMO_URL="$_probe_url"
            echo ""
            echo "  Auto-detected server at $_probe_url"
        else
            echo ""
            echo "  No server found at localhost:8765."
            echo ""
            echo -n "  Enter your MEMO_URL (e.g. http://localhost:8765/api/memory): "
            read -r MEMO_URL
            if [[ -z "$MEMO_URL" ]]; then
                echo ""
                echo "  ⚠  No server configured — memories will NOT be saved."
                echo "     Re-run: memo calibrate"
                return 0
            fi
            # Auto-generate a token if none set
            if [[ -z "${MEMO_TOKEN:-}" ]]; then
                MEMO_TOKEN=$(LC_ALL=C tr -dc 'A-Za-z0-9' </dev/urandom | head -c 40 2>/dev/null \
                             || cat /proc/sys/kernel/random/uuid 2>/dev/null | tr -d '-' | head -c 40)
                TOKEN_HEADER=(-H "Authorization: Bearer ${MEMO_TOKEN}")
                _auto_token_generated=true
            fi
            # Persist to ~/.memorc
            {
                printf '\nMEMO_URL=%s\n' "$MEMO_URL"
                [[ "$_auto_token_generated" == true ]] && printf 'MEMO_TOKEN=%s\n' "$MEMO_TOKEN"
            } >> "$HOME/.memorc"
            echo ""
            echo "  Saved to ~/.memorc — future runs need no configuration."
            [[ "$_auto_token_generated" == true ]] && \
                echo "  Auto-generated token: $MEMO_TOKEN  (add to your app's auth_fn)"
        fi
    fi

    # Auto-detect scope
    if [[ -z "$scope" ]]; then
        if [[ -n "${MEMO_SCOPE:-}" ]]; then
            scope="$MEMO_SCOPE"
        else
            local remote; remote=$(git -C "$root" remote get-url origin 2>/dev/null || echo "")
            if [[ -n "$remote" ]]; then
                scope="repo:$(basename "$remote" .git)"
            else
                scope="repo:$(basename "$(cd "$root" && pwd)")"
            fi
        fi
    fi

    echo ""
    echo "Ingesting codebase → scope: $scope"

    # Get last calibrated commit for incremental git scanning
    local since_sha=""
    since_sha=$(curl -sS -G "${MEMO_URL}/kg/query" "${TOKEN_HEADER[@]}" \
        --data-urlencode "scope=$scope" \
        --data-urlencode "subject=calibrate" \
        --data-urlencode "predicate=last_commit" 2>/dev/null | \
        jq -r '(.results // []) | if type=="array" then .[0] else ."1" end | .object // empty' \
        2>/dev/null || echo "")
    [[ -n "$since_sha" ]] && echo "  (incremental: commits since ${since_sha:0:7})"

    # Build Lua flags for the scan phase
    local scan_flags="[==[--scan]==],[==[--scope]==],[==[${scope}]==],[==[--root]==],[==[${root}]==],"
    [[ -n "$since_sha" ]] && scan_flags+="[==[--since-commit]==],[==[${since_sha}]==],"
    [[ "$no_git" == true      ]] && scan_flags+="[==[--no-git]==],"
    [[ "$no_comments" == true ]] && scan_flags+="[==[--no-comments]==],"

    # ── Phase 3: scan → POST /write ─────────────────────────────────────────
    local count=0 errors=0
    while IFS= read -r mem_line; do
        [[ -z "$mem_line" ]] && continue
        if [[ "$dry_run" == true ]]; then
            local title; title=$(printf '%s' "$mem_line" | jq -r '.title // "(no title)"' 2>/dev/null)
            echo "  [dry-run] $title"
            (( count++ )) || true
        else
            local resp
            resp=$(curl -sS -X POST "${MEMO_URL}/write" \
                "${TOKEN_HEADER[@]}" \
                -H "Content-Type: application/json" \
                -d "$mem_line" 2>/dev/null)
            if printf '%s' "$resp" | jq -e '.ok' >/dev/null 2>&1; then
                local title; title=$(printf '%s' "$resp" | jq -r '.result.title // "(ok)"' 2>/dev/null)
                echo "  + $title"
                (( count++ )) || true
            else
                (( errors++ )) || true
            fi
        fi
    done < <("$lua" -e "require('luamemo.cli.calibrate').run({${scan_flags}})")

    echo ""
    if [[ "$dry_run" == true ]]; then
        echo "  [dry-run] Would write $count memories. Re-run without --dry-run to apply."
    else
        echo "  Done: $count memories written ($errors errors) to scope=$scope"
    fi

    # Update KG cursor so next calibrate only processes new commits
    if [[ "$dry_run" != true ]] && [[ "$no_git" != true ]]; then
        local head_sha; head_sha=$(git -C "$root" rev-parse HEAD 2>/dev/null || echo "")
        if [[ -n "$head_sha" ]]; then
            curl -sS -X POST "${MEMO_URL}/kg/assert" "${TOKEN_HEADER[@]}" \
                -H "Content-Type: application/json" \
                -d "{\"scope\":\"${scope}\",\"subject\":\"calibrate\",\"predicate\":\"last_commit\",\"object\":\"${head_sha}\",\"supersede\":true}" \
                >/dev/null 2>&1 || true
        fi
    fi
}

# Find a Lua interpreter for local subcommands (calibrate, doctor) that bypass
# the HTTP API and load the library modules directly.
find_lua() {
    for cand in lua5.1 luajit lua5.3 lua5.4 lua; do
        if command -v "$cand" >/dev/null; then echo "$cand"; return 0; fi
    done
    return 1
}

cmd_local_lua() {
    local module="$1"; shift
    local lua
    if ! lua=$(find_lua); then
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    fi
    # Build a Lua array literal of string args. Each arg goes inside
    # Lua long-bracket quotes ([==[...]==]) so embedded special chars
    # (quotes, backslashes, brackets) do not need escaping.
    local args=""
    for a in "$@"; do
        args+="[==[${a}]==],"
    done
    "$lua" -e "require('luamemo.cli.${module}').run({${args}})"
}

usage() {
    sed -n '2,31p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
}

[[ $# -lt 1 ]] && usage
sub="$1"; shift

# calibrate/doctor/migrate: probe phase doesn't need MEMO_URL.
case "$sub" in
    calibrate|doctor|migrate) ;;
    *) : "${MEMO_URL:?MEMO_URL is not set}" ;;
esac

case "$sub" in
    write)  cmd_write  "$@" ;;
    search) cmd_search "$@" ;;
    recent) cmd_recent "$@" ;;
    get)    cmd_get    "$@" ;;
    update) cmd_update "$@" ;;
    delete) cmd_delete "$@" ;;
    summarize) cmd_summarize "$@" ;;
    promote) cmd_promote "$@" ;;
    context) cmd_context "$@" ;;
    consolidate) cmd_consolidate "$@" ;;
    calibrate) cmd_calibrate "$@" ;;
    secret-store)   cmd_secret_store   "$@" ;;
    secret-list)    cmd_secret_list         ;;
    secret-delete)  cmd_secret_delete  "$@" ;;
    secret-execute) cmd_secret_execute "$@" ;;
    migrate) cmd_migrate ;;
    doctor)  cmd_local_lua doctor "$@" ;;
    -h|--help|help) usage ;;
    *) echo "memo: unknown subcommand: $sub" >&2; usage ;;
esac
