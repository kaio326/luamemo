# Used by --docker-compose FILE flag in cmd_calibrate.
# Parses a docker-compose.yml for Postgres credentials and host port,
# then exports MEMO_DB_URL.
# ---------------------------------------------------------------------------
_parse_compose_pg() {
    local file="$1"
    if [[ ! -f "$file" ]]; then
        echo "memo calibrate: --docker-compose: file not found: $file" >&2
        return 1
    fi

    local pg_user="" pg_pass="" pg_db="" pg_port=""
    local in_pg_service=false in_environment=false

    while IFS= read -r line; do
        # Detect a service whose image contains "postgres"
        if [[ "$line" =~ ^[[:space:]]+image:[[:space:]].*postgres ]]; then
            in_pg_service=true
            in_environment=false
        fi
        # Detect a new 2-indent service name line (reset if leaving pg service)
        if [[ "$in_pg_service" == true ]] && \
           [[ "$line" =~ ^[[:space:]]{2}[a-zA-Z][a-zA-Z0-9_-]*:[[:space:]]*$ ]]; then
            # Only reset if we've already entered the pg service block
            # (any new 2-space service after the pg one ends its scope)
            in_pg_service=false
            in_environment=false
        fi
        if [[ "$in_pg_service" == true ]]; then
            # Begin of environment: block
            if [[ "$line" =~ ^[[:space:]]+environment:[[:space:]]*$ ]]; then
                in_environment=true
                continue
            fi
            # End of environment: section when another key at the same indent level appears
            if [[ "$in_environment" == true ]] && \
               [[ "$line" =~ ^[[:space:]]{4}[a-zA-Z] ]] && \
               ! [[ "$line" =~ POSTGRES_ ]]; then
                in_environment=false
            fi
            if [[ "$in_environment" == true ]]; then
                # Support both "  - KEY=VALUE" list form and "KEY: VALUE" map form
                local stripped="${line#"${line%%[! ]*}"}"   # ltrim
                if [[ "$stripped" =~ ^-[[:space:]]POSTGRES_USER=(.*)$ ]]; then
                    pg_user="${BASH_REMATCH[1]}"
                elif [[ "$stripped" =~ ^POSTGRES_USER:[[:space:]]*(.*)$ ]]; then
                    pg_user="${BASH_REMATCH[1]}"
                fi
                if [[ "$stripped" =~ ^-[[:space:]]POSTGRES_PASSWORD=(.*)$ ]]; then
                    pg_pass="${BASH_REMATCH[1]}"
                elif [[ "$stripped" =~ ^POSTGRES_PASSWORD:[[:space:]]*(.*)$ ]]; then
                    pg_pass="${BASH_REMATCH[1]}"
                fi
                if [[ "$stripped" =~ ^-[[:space:]]POSTGRES_DB=(.*)$ ]]; then
                    pg_db="${BASH_REMATCH[1]}"
                elif [[ "$stripped" =~ ^POSTGRES_DB:[[:space:]]*(.*)$ ]]; then
                    pg_db="${BASH_REMATCH[1]}"
                fi
            fi
            # ports: "HOST_PORT:5432"
            if [[ "$line" =~ ([0-9]+):5432 ]]; then
                pg_port="${BASH_REMATCH[1]}"
            fi
        fi
    done < "$file"

    pg_user="${pg_user:-postgres}"
    pg_db="${pg_db:-luamemo}"
    pg_port="${pg_port:-5432}"

    if [[ -z "$pg_pass" ]]; then
        echo "memo calibrate: --docker-compose: POSTGRES_PASSWORD not found in $file" >&2
        echo "  Set MEMO_DB_URL manually or add POSTGRES_PASSWORD to the Compose file." >&2
        return 1
    fi

    export MEMO_DB_URL="postgresql://${pg_user}:${pg_pass}@localhost:${pg_port}/${pg_db}"
    echo "  Docker Compose: detected Postgres → MEMO_DB_URL=${MEMO_DB_URL//:${pg_pass}@/:***@}"
}

# ---------------------------------------------------------------------------
# memo calibrate — three-phase host probe, corpus health check, codebase ingest.
# ---------------------------------------------------------------------------
cmd_calibrate() {
    local root="." scope="" dry_run=false no_git=false no_comments=false probe_only=false
    local no_migrate=false no_mcp=false dc_file=""
    local lua_extra_flags=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --root)        root="$2";        shift 2 ;;
            --scope)       scope="$2";       shift 2 ;;
            --dry-run)     dry_run=true;     shift   ;;
            --no-git)      no_git=true;      shift   ;;
            --no-comments) no_comments=true; shift   ;;
            --probe-only)  probe_only=true;  shift   ;;
            --no-migrate)  no_migrate=true;  shift   ;;
            --no-mcp)      no_mcp=true;      shift   ;;
            --docker-compose) dc_file="$2";  shift 2 ;;
            --non-interactive|--multilingual|--long|--hosted|--allow-hash)
                lua_extra_flags+="[==[${1}]==],"; shift ;;
            --write)
                lua_extra_flags+="[==[--write]==],[==[${2}]==],"; shift 2 ;;
            *) echo "memo calibrate: unknown arg: $1" >&2; exit 1 ;;
        esac
    done

    local lua; lua=$(find_lua) || {
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    }

    # ── Phase 1: host probe + embedder recommendation (no DB required) ──────
    # Apply --docker-compose credentials before probe so they're visible in output.
    if [[ -n "$dc_file" ]]; then
        _parse_compose_pg "$dc_file" || true
    fi

    "$lua" -e "require('luamemo.cli.calibrate').run({[==[--root]==],[==[${root}]==],${lua_extra_flags}})"
    [[ "$probe_only" == true ]] && return 0

    # ── Phase 2: resolve DB connection ──────────────────────────────────────
    # Resolution order:
    #   1. $MEMO_DB_URL env var (from ~/.memorc or explicit)
    #   2. Individual PG* env vars (PGHOST etc.)
    #   3. Prompt once, save to ~/.memorc

    if [[ -z "${MEMO_DB_URL:-}" ]] && \
       [[ -z "${PGHOST:-}" ]] && [[ -z "${PGDATABASE:-}" ]]; then
        echo ""
        echo "  No database config found."
        echo -n "  Enter MEMO_DB_URL (e.g. postgresql://postgres:@127.0.0.1:5432/luamemo): "
        read -r MEMO_DB_URL
        if [[ -z "$MEMO_DB_URL" ]]; then
            echo ""
            echo "  No database configured — memories will NOT be saved."
            echo "     Re-run: memo calibrate"
            return 0
        fi
        printf '\nMEMO_DB_URL=%s\n' "$MEMO_DB_URL" >> "$HOME/.memorc"
        echo ""
        echo "  Saved to ~/.memorc — future runs need no configuration."
        export MEMO_DB_URL
    fi

    # ── Phase 2.5: schema check ─────────────────────────────────────────────
    # Query information_schema to verify lm_memories and lm_kg_facts exist
    # and carry all expected columns.  If anything is missing, offer to apply
    # the full schema automatically (requires psql on PATH).
    if [[ "${no_migrate:-false}" != "true" ]]; then
        echo ""
        echo "Checking schema..."

        local schema_result
        schema_result=$(printf '{}' | api_call schema-check 2>/dev/null || echo '{"ok":false,"db_error":"api call failed"}')

        local schema_ok
        schema_ok=$(printf '%s' "$schema_result" | jq -r '.ok // false' 2>/dev/null || echo "false")

        if [[ "$schema_ok" == "true" ]]; then
            echo "  Schema: OK"
        else
            # Collect details: which tables are missing or have missing columns.
            local mem_present mem_missing kg_present kg_missing
            mem_present=$(printf '%s' "$schema_result" | jq -r '.tables.lm_memories.present // false' 2>/dev/null || echo "false")
            mem_missing=$(printf '%s' "$schema_result" | jq -r '(.tables.lm_memories.missing_cols // []) | join(", ")' 2>/dev/null || echo "")
            kg_present=$(printf '%s' "$schema_result" | jq -r '.tables.lm_kg_facts.present // false' 2>/dev/null || echo "false")
            kg_missing=$(printf '%s' "$schema_result" | jq -r '(.tables.lm_kg_facts.missing_cols // []) | join(", ")' 2>/dev/null || echo "")

            echo "  Schema: incomplete"
            [[ "$mem_present" != "true" ]] && echo "    - lm_memories table: missing"
            [[ "$mem_present" == "true" ]] && [[ -n "$mem_missing" ]] && echo "    - lm_memories columns missing: $mem_missing"
            [[ "$kg_present" != "true" ]] && echo "    - lm_kg_facts table: missing"
            [[ "$kg_present" == "true" ]] && [[ -n "$kg_missing" ]] && echo "    - lm_kg_facts columns missing: $kg_missing"
            echo ""

            local do_migrate="n"
            if command -v psql >/dev/null 2>&1; then
                echo -n "  Apply schema now? [y/N] "
                read -r do_migrate
            else
                echo "  psql not found — cannot apply schema automatically."
            fi

            if [[ "$do_migrate" =~ ^[Yy]$ ]]; then
                echo "  Applying schema..."
                if cmd_migrate | PGPASSWORD="${PGPASSWORD:-}" psql "$MEMO_DB_URL" -v ON_ERROR_STOP=1 -q; then
                    echo "  Schema applied successfully."
                else
                    echo ""
                    echo "  ERROR: psql exited with an error. Check the output above." >&2
                    echo "  You can apply the schema manually:" >&2
                    echo "    memo migrate | psql \"\$MEMO_DB_URL\"" >&2
                    echo "  Codebase ingest will be skipped until the schema is ready." >&2
                    return 1
                fi
            else
                echo ""
                echo "  Schema not applied. Memories cannot be stored without it."
                echo "  To apply manually:"
                echo "    memo migrate | psql \"$MEMO_DB_URL\""
                echo ""
                echo "  Without the schema, codebase ingest will fail."
                echo "  Re-run memo calibrate once the schema is in place."
                return 0
            fi
        fi
    fi

    # ── Phase 3: auto-detect scope ──────────────────────────────────────────
    if [[ -z "$scope" ]]; then
        if [[ -n "${MEMO_SCOPE:-}" ]]; then
            scope="$MEMO_SCOPE"
        else
            local remote; remote=$(git -C "$root" remote get-url origin 2>/dev/null || echo "")
            if [[ -n "$remote" ]]; then
                scope="repo:$(basename "$remote" .git)"
            else
                scope="repo:$(basename "$(cd "$root" && pwd)")"
            fi
        fi
    fi

    echo ""
    echo "Ingesting codebase → scope: $scope"

    # Get last calibrated commit for incremental scanning (via KG)
    local since_sha=""
    since_sha=$(jq -n \
        --arg scope "$scope" \
        '{scope: $scope, subject: "calibrate", predicate: "last_commit", limit: 1}' \
        | api_call kg-query \
        | jq -r '(.results // []) | if type=="array" then .[0] else ."1" end | .object // empty' \
        2>/dev/null || echo "")
    [[ -n "$since_sha" ]] && echo "  (incremental: commits since ${since_sha:0:7})"

    # Build Lua flags for the scan phase
    local scan_flags="[==[--scan]==],[==[--scope]==],[==[${scope}]==],[==[--root]==],[==[${root}]==],"
    [[ -n "$since_sha" ]] && scan_flags+="[==[--since-commit]==],[==[${since_sha}]==],"
    [[ "$no_git" == true      ]] && scan_flags+="[==[--no-git]==],"
    [[ "$no_comments" == true ]] && scan_flags+="[==[--no-comments]==],"

    # ── Phase 4: scan → write (single Lua process handles all writes) ────────
    local count=0 errors=0
    if [[ "$dry_run" == true ]]; then
        while IFS= read -r mem_line; do
            [[ -z "$mem_line" ]] && continue
            local title; title=$(printf '%s' "$mem_line" | jq -r '.title // "(no title)"' 2>/dev/null)
            echo "  [dry-run] $title"
            (( count++ )) || true
        done < <("$lua" -e "require('luamemo.cli.calibrate').run({${scan_flags}})")
        echo ""
        echo "  [dry-run] Would write $count memories. Re-run without --dry-run to apply."
    else
        while IFS= read -r result_line; do
            [[ -z "$result_line" ]] && continue
            local ok; ok=$(printf '%s' "$result_line" | jq -r '.ok // false' 2>/dev/null)
            if [[ "$ok" == "true" ]]; then
                (( count++ )) || true
            else
                (( errors++ )) || true
            fi
        done < <(
            "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.calibrate').run({${scan_flags}})" \
            | "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.api').dispatch('write-many')"
        )
        echo ""
        echo "  Done: $count memories written ($errors errors) to scope=$scope"
    fi

    # Update KG cursor so next calibrate only processes new commits
    if [[ "$dry_run" != true ]] && [[ "$no_git" != true ]]; then
        local head_sha; head_sha=$(git -C "$root" rev-parse HEAD 2>/dev/null || echo "")
        if [[ -n "$head_sha" ]]; then
            jq -n \
                --arg scope "$scope" \
                --arg sha "$head_sha" \
                '{scope: $scope, subject: "calibrate", predicate: "last_commit", object: $sha, supersede: true}' \
            | api_call kg-assert >/dev/null 2>&1 || true
        fi
    fi

    # ── Phase 5: IDE detection + MCP config ─────────────────────────────────
    if [[ "${no_mcp:-false}" != "true" ]]; then
        _calibrate_mcp_phase "$root" "$scope"
    fi
}

# ---------------------------------------------------------------------------
# IDE detection + MCP config writer (called from cmd_calibrate phase 5)
# ---------------------------------------------------------------------------
_calibrate_mcp_phase() {
    local root="$1" scope="$2"

    local lua_bin; lua_bin=$(find_lua) || lua_bin="lua"
    local script_dir; script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
    # Resolve absolute path to mcp/server.lua.
    # When installed via LuaRocks, this script lands in a bin/ directory and
    # the naive "${script_dir}/../mcp/server.lua" resolves to a non-existent
    # path.  We try four strategies in order:
    #   1. Relative to this script (works in git-repo / dev mode).
    #   2. luarocks show — asks the installed package manager for the prefix.
    #   3. find in common LuaRocks tree roots (slow but reliable fallback).
    #   4. Keep the relative path and warn the user to fix it manually.
    local mcp_server=""
    local _rel="${script_dir}/../mcp/server.lua"
    if [[ -f "$_rel" ]]; then
        command -v realpath >/dev/null 2>&1 \
            && mcp_server=$(realpath "$_rel" 2>/dev/null) \
            || mcp_server="$_rel"
    fi

    if [[ -z "$mcp_server" ]]; then
        # Strategy 2: ask luarocks for the install prefix.
        local _lr_prefix=""
        for _lr in luarocks-5.1 luarocks; do
            if command -v "$_lr" >/dev/null 2>&1; then
                _lr_prefix=$("$_lr" show luamemo 2>/dev/null \
                    | grep -i "installed in:" | head -1 \
                    | sed 's/.*[Ii]nstalled in:[[:space:]]*//')
                [[ -n "$_lr_prefix" ]] && break
            fi
        done
        if [[ -n "$_lr_prefix" ]]; then
            local _srv
            _srv=$(find "$_lr_prefix/lib/luarocks" \
                -path "*/luamemo/*/mcp/server.lua" 2>/dev/null | sort -V | tail -1)
            [[ -n "$_srv" ]] && mcp_server="$_srv"
        fi
    fi

    if [[ -z "$mcp_server" ]]; then
        # Strategy 3: search common LuaRocks tree roots.
        local _srv
        for _prefix in "${HOME}/.luarocks" "/usr/local" "/usr"; do
            if [[ -d "${_prefix}/lib/luarocks" ]]; then
                _srv=$(find "${_prefix}/lib/luarocks" -maxdepth 8 \
                    -path "*/luamemo/*/mcp/server.lua" 2>/dev/null | sort -V | tail -1)
                if [[ -n "$_srv" ]]; then
                    mcp_server="$_srv"
                    break
                fi
            fi
        done
    fi

    # Strategy 4: fall back to the relative path; warn below if it doesn't exist.
    [[ -z "$mcp_server" ]] && mcp_server="$_rel"

    # Block if the server file still can't be found — writing a broken path
    # into the MCP client config causes silent failures that are hard to debug.
    if [[ ! -f "$mcp_server" ]]; then
        echo ""
        echo "  WARNING: mcp/server.lua not found at:"
        echo "    $mcp_server"
        if [[ -t 0 ]]; then
            echo -n "  Enter the correct path to mcp/server.lua (or press Enter to skip MCP config): "
            local _user_path; read -r _user_path
            if [[ -z "$_user_path" ]]; then
                echo "  Skipping MCP config write (no valid server path)."
                echo "  To configure manually, set 'args' in your MCP client config to"
                echo "  the path of mcp/server.lua from the luamemo LuaRocks installation."
                return 0
            elif [[ -f "$_user_path" ]]; then
                mcp_server="$_user_path"
            else
                echo "  Path does not exist: $_user_path"
                echo "  Skipping MCP config write."
                return 0
            fi
        else
            echo "  Non-interactive: skipping MCP config write."
            echo "  Typical location: <luarocks-prefix>/lib/luarocks/rocks-5.1/luamemo/<ver>/mcp/server.lua"
            return 0
        fi
    fi

    local db_url="${MEMO_DB_URL:-}"

    # Warn if the URL is empty — a blank MEMO_DB_URL in the generated config
    # causes the MCP server to silently fail to connect on first use.
    if [[ -z "$db_url" ]]; then
        echo ""
        echo "  WARNING: MEMO_DB_URL is not set."
        echo "  The generated MCP config will have an empty MEMO_DB_URL and the"
        echo "  MCP server will fail to connect to Postgres."
        echo "  Set MEMO_DB_URL before running memo calibrate, or edit the"
        echo "  env.MEMO_DB_URL field in the generated config manually."
        echo "  Example: export MEMO_DB_URL=postgresql://user:pass@localhost:5432/luamemo"
    fi

    # Build the MCP server env block (JSON).
    local mcp_env
    mcp_env=$(jq -n \
        --arg db  "$db_url" \
        --arg sc  "$scope" \
        '{"MEMO_DB_URL": $db, "MEMO_SCOPE": $sc}')

    # Build the VS Code / Claude Desktop / Cursor MCP entry (JSON).
    local vscode_entry
    vscode_entry=$(jq -n \
        --arg cmd "$lua_bin" \
        --arg srv "$mcp_server" \
        --argjson env "$mcp_env" \
        '{"type":"stdio","command":$cmd,"args":[$srv],"env":$env}')

    local claude_entry
    claude_entry=$(jq -n \
        --arg cmd "$lua_bin" \
        --arg srv "$mcp_server" \
        --argjson env "$mcp_env" \
        '{"command":$cmd,"args":[$srv],"env":$env}')

    echo ""
    echo "MCP client configuration"
    echo "========================"

    # ── VS Code (.vscode/mcp.json) ───────────────────────────────────────
    local vscode_dir="${root}/.vscode"
    local vscode_mcp="${vscode_dir}/mcp.json"
    local has_vscode=false
    [[ -d "$vscode_dir" ]] && has_vscode=true

    if [[ "$has_vscode" == "true" ]]; then
        echo "  Detected: VS Code workspace (.vscode/ found)"
        if [[ -f "$vscode_mcp" ]]; then
            # Check if luamemo entry already exists.
            local already
            already=$(jq -r '.servers.luamemo // empty' "$vscode_mcp" 2>/dev/null || echo "")
            if [[ -n "$already" ]]; then
                echo "  .vscode/mcp.json: luamemo entry already present — skipping."
            else
                echo -n "  Write luamemo MCP entry to .vscode/mcp.json? [y/N] "
                local ans; read -r ans
                if [[ "$ans" =~ ^[Yy]$ ]]; then
                    local updated
                    updated=$(jq --argjson entry "$vscode_entry" '.servers.luamemo = $entry' "$vscode_mcp")
                    printf '%s\n' "$updated" > "$vscode_mcp"
                    echo "  Updated: $vscode_mcp"
                fi
            fi
        else
            echo -n "  Create .vscode/mcp.json with luamemo entry? [y/N] "
            local ans; read -r ans
            if [[ "$ans" =~ ^[Yy]$ ]]; then
                mkdir -p "$vscode_dir"
                jq -n --argjson entry "$vscode_entry" '{"servers":{"luamemo":$entry}}' > "$vscode_mcp"
                echo "  Created: $vscode_mcp"
            fi
        fi
    fi

    # ── Cursor (~/.cursor/mcp.json) ──────────────────────────────────────
    local cursor_mcp="${HOME}/.cursor/mcp.json"
    if [[ -d "${HOME}/.cursor" ]]; then
        echo "  Detected: Cursor (~/.cursor/ found)"
        if [[ -f "$cursor_mcp" ]]; then
            local already
            already=$(jq -r '.mcpServers.luamemo // empty' "$cursor_mcp" 2>/dev/null || echo "")
            if [[ -n "$already" ]]; then
                echo "  ~/.cursor/mcp.json: luamemo entry already present — skipping."
            else
                echo -n "  Write luamemo MCP entry to ~/.cursor/mcp.json? [y/N] "
                local ans; read -r ans
                if [[ "$ans" =~ ^[Yy]$ ]]; then
                    local updated
                    updated=$(jq --argjson entry "$claude_entry" '.mcpServers.luamemo = $entry' "$cursor_mcp")
                    printf '%s\n' "$updated" > "$cursor_mcp"
                    echo "  Updated: $cursor_mcp"
                fi
            fi
        else
            echo -n "  Create ~/.cursor/mcp.json with luamemo entry? [y/N] "
            local ans; read -r ans
            if [[ "$ans" =~ ^[Yy]$ ]]; then
                jq -n --argjson entry "$claude_entry" '{"mcpServers":{"luamemo":$entry}}' > "$cursor_mcp"
                echo "  Created: $cursor_mcp"
            fi
        fi
    fi

    # ── Claude Desktop ───────────────────────────────────────────────────
    local claude_cfg=""
    if [[ "$(uname)" == "Darwin" ]]; then
        claude_cfg="${HOME}/Library/Application Support/Claude/claude_desktop_config.json"
    else
        claude_cfg="${HOME}/.config/Claude/claude_desktop_config.json"
    fi
    if [[ -f "$claude_cfg" ]]; then
        echo "  Detected: Claude Desktop (${claude_cfg})"
        local already
        already=$(jq -r '.mcpServers.luamemo // empty' "$claude_cfg" 2>/dev/null || echo "")
        if [[ -n "$already" ]]; then
            echo "  claude_desktop_config.json: luamemo entry already present — skipping."
        else
            echo -n "  Write luamemo MCP entry to Claude Desktop config? [y/N] "
            local ans; read -r ans
            if [[ "$ans" =~ ^[Yy]$ ]]; then
                local updated
                updated=$(jq --argjson entry "$claude_entry" '.mcpServers.luamemo = $entry' "$claude_cfg")
                printf '%s\n' "$updated" > "$claude_cfg"
                echo "  Updated: $claude_cfg"
            fi
        fi
    fi

    # ── Nothing detected — print manual instructions ─────────────────────
    if [[ "$has_vscode" != "true" ]] && [[ ! -d "${HOME}/.cursor" ]] && [[ ! -f "$claude_cfg" ]]; then
        echo "  No IDE config detected. Add this to your MCP client config manually:"
        echo ""
        echo "  VS Code (.vscode/mcp.json):"
        jq -n --argjson entry "$vscode_entry" '{"servers":{"luamemo":$entry}}' | sed 's/^/    /'
        echo ""
        echo "  Claude Desktop / Cursor (mcpServers block):"
        jq -n --argjson entry "$claude_entry" '{"mcpServers":{"luamemo":$entry}}' | sed 's/^/    /'
    fi

    echo ""
    echo "  Note: memory.setup() and routes.register() are only needed if your"
    echo "  application code calls store.write/search in-process, or you want"
    echo "  the /api/memory HTTP routes available to non-MCP clients."
    echo "  For Copilot Agent Mode, Cursor, or Claude Desktop using MEMO_DB_URL,"
    echo "  the MCP server above handles everything — no setup() call required."
    echo ""
    echo "  IMPORTANT — verify MEMO_DB_URL for your deployment environment:"
    echo "  The MCP server connects to Postgres using the MEMO_DB_URL value above."
    echo "  In Docker deployments 127.0.0.1 is the MCP client host, not the"
    echo "  container. Use the service name or a host-routable address instead,"
    echo "  e.g. postgresql://user:pass@db:5432/luamemo"
    echo "  Update the env.MEMO_DB_URL field in the generated config if needed."
    echo ""
}

cmd_local_lua() {
    local module="$1"; shift
    local lua
    if ! lua=$(find_lua); then
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    fi
    local args=""
    for a in "$@"; do
        args+="[==[${a}]==],"
    done
    "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.${module}').run({${args}})"
}

usage() {
    sed -n '2,31p' "$0" | sed 's/^# \{0,1\}//'
    exit 1
}

[[ $# -lt 1 ]] && usage
sub="$1"; shift

case "$sub" in
    write)  cmd_write  "$@" ;;
    search) cmd_search "$@" ;;
    recent) cmd_recent "$@" ;;
    get)    cmd_get    "$@" ;;
    update) cmd_update "$@" ;;
    delete) cmd_delete "$@" ;;
    summarize) cmd_summarize "$@" ;;
    promote) cmd_promote "$@" ;;
    context) cmd_context "$@" ;;
    consolidate) cmd_consolidate "$@" ;;
    digest) cmd_digest "$@" ;;
    calibrate) cmd_calibrate "$@" ;;
    secret-store)   cmd_secret_store   "$@" ;;
    secret-list)    cmd_secret_list         ;;
    secret-delete)  cmd_secret_delete  "$@" ;;
    secret-execute) cmd_secret_execute "$@" ;;
    migrate) cmd_migrate ;;
    ping)    cmd_local_lua ping    "$@" ;;
    doctor)  cmd_local_lua doctor  "$@" ;;
    -h|--help|help) usage ;;
    *) echo "memo: unknown subcommand: $sub" >&2; usage ;;
esac