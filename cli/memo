#!/usr/bin/env bash
# memo — luamemo CLI: persistent semantic memory for AI agents.
#
# Stores and retrieves memories in PostgreSQL using hybrid vector + full-text
# search. Supports pluggable embedders (Ollama, OpenAI, TEI, built-in hash),
# knowledge graphs, encrypted secrets, memory tiers (0–3), a whole-repo codebase
# index (memo index), and an MCP stdio server so AI agents can read/write memory
# and query the code map directly. Works with plain PostgreSQL + Lua 5.1 — no
# OpenResty required.
#
# Configuration (env vars or ~/.memorc):
#   MEMO_DB_URL   PostgreSQL connection URL, e.g.
#                 postgresql://user:pass@localhost:5432/luamemo
#                 (Individual PGHOST/PGPORT/PGDATABASE/PGUSER/PGPASSWORD also work)
#
# Commands:
#   memo write      --scope SCOPE --kind KIND --title T --body B [--tags a,b,c]
#                   [--importance F]
#
#   memo search     QUERY [--scope SCOPE] [--kind KIND] [--limit N]
#                         [--since ISO|EPOCH] [--until ISO|EPOCH]
#                         [--tier-min N] [--tier-max N]
#
#   memo recent     [--scope SCOPE] [--limit N]
#
#   memo get        ID
#
#   memo update     ID [--title T] [--body B] [--scope S] [--kind K] [--tags a,b]
#
#   memo delete     ID
#
#   memo context    QUERY [--scope SCOPE] [--limit N] [--no-kg] [--format text|json]
#                   (search + KG facts in one call, formatted for agent consumption)
#
#   memo brief      [--scope SCOPE]
#                   (tiny session-start digest: memory count + codebase-map size +
#                    tool hints; fail-soft, for auto-injection via a SessionStart hook)
#
#   memo consolidate [--scope SCOPE] [--dry-run] [--similarity-threshold F]
#                    [--decay-threshold F] [--max-rows N]
#                    (cluster related memories into observations)
#
#   memo digest     [--scope SCOPE] [--dry-run] [--threshold F]
#                   (hippocampus digest: promote tiers, delete stale ephemeral rows)
#
#   memo sense      --scope SCOPE [--generative] [--min-similarity F]
#                   (stdin: JSON array of {role,text} turns → record reinforcements)
#
#   memo learn      <scope> [--dry-run] [--min-samples N] [--margin F]
#                   (per-scope promotion harness: harvest → train → gated-promote reranker)
#
#   memo reembed    --scope SCOPE [--batch N] [--dry-run]
#                   (re-embed every memory in a scope with the current embedder —
#                    needed after switching embedders; old vectors aren't comparable)
#
#   memo promote    --from FROM_SCOPE --to TO_SCOPE [--delete-source] [--dry-run]
#                   [--limit N]
#
#   memo summarize  [--scope S] [--dry-run] [--weight-threshold F]
#                   [--retention-days N]
#
#   memo index      ingest [--root .] [--scope codeindex:proj] [--extensions csv|*]
#                          [--no-symbols] [--embed-file-rows] [--exclude a,b] [--dry-run]
#                   update [--root .] [--scope codeindex:proj]
#                   search  <query>  [--scope codeindex:proj] [--kind symbol] [--limit N]
#                   explore <query>  [--scope codeindex:proj] [--limit N]
#                   status           [--scope codeindex:proj]
#                   invalidate <file|scope>
#                   diff   --commit SHA | --file FILE | --stdin [--scope codeindex:proj]
#                   (index a repo into codeindex:<project> — files/symbols/deps/diffs;
#                    Lua/Python/JS-TS parsers + universal-ctags for other languages)
#
#   memo calibrate  [--scope SCOPE] [--root DIR] [--no-git] [--no-comments]
#                   [--probe-only] [--multilingual] [--long] [--hosted]
#                   [--allow-hash] [--write PATH] [--no-migrate] [--no-mcp]
#                   [--no-plugin] [--docker-compose FILE] [--dry-run]
#                   [--keep-embedder] [-h|--help]
#                   (probe host + recommend embedder + ingest codebase)
#                   --keep-embedder: skip probe-and-persist, preserve existing
#                   embedder config in .luamemorc
#                   --no-plugin: skip VS Code agent plugin install
#                   -h, --help: show calibrate flag reference and exit
#
#   memo ping       [--db] [--table] [--embedder]   Connectivity check (exit 0/1)
#
#   memo setup      [--root DIR] [--force]
#                   Create SETUP_CHECK in the project root with first-run
#                   verification instructions for an AI agent. The file is
#                   deleted automatically when `memo calibrate` succeeds.
#
#   memo doctor     [--setup PATH] [--json]
#                   (corpus health: truncation counts, p95 row size, scale warnings)
#
#   memo migrate    Print all luamemo migration SQL to stdout (pipe to psql)
#
#   memo secret-store   NAME [--desc DESCRIPTION] [--file PATH]
#   memo secret-list
#   memo secret-delete  NAME
#   memo secret-execute NAME URL [--method M] [--header K:V]...
#                               [--body TEXT] [--form FIELD=VALUE]...
#                               [--form-file FIELD:PATH] [--timeout-ms N]
#
#   memo help | --help | -h

set -euo pipefail

# Load ~/.memorc if present (global defaults, for backward compatibility).
# set -a / set +a ensures every KEY=VALUE line is automatically exported so
# child Lua processes (api.lua, mcp/server.lua) inherit the vars without the
# caller needing to prefix each line with "export".
_MEMO_CONFIG_SOURCE=""
if [[ -f "$HOME/.memorc" ]]; then
    # shellcheck disable=SC1091
    set -a; source "$HOME/.memorc"; set +a
    [[ -n "${MEMO_DB_URL:-}" ]] && _MEMO_CONFIG_SOURCE="global"
fi
# Load .luamemorc from the current directory — project-local config overrides
# the global ~/.memorc.  This allows multiple projects on the same machine to
# each have their own database without interfering with one another.
if [[ -f "$PWD/.luamemorc" ]]; then
    # shellcheck disable=SC1091
    set -a; source "$PWD/.luamemorc"; set +a
    [[ -n "${MEMO_DB_URL:-}" ]] && _MEMO_CONFIG_SOURCE="local"
fi

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

require_jq() {
    if ! command -v jq >/dev/null; then
        echo "memo: 'jq' is required but not installed" >&2
        exit 1
    fi
}

find_lua() {
    # The in-process GGUF embedder (MEMO_EMBEDDER=gguf_ffi) needs LuaJIT's FFI, so
    # prefer luajit when it is the selected embedder; otherwise the standard
    # lua5.1-first order. (.luamemorc is sourced with `set -a`, so MEMO_EMBEDDER is
    # in the environment here.) Mirrors the MCP config writer's luajit selection.
    local order="lua5.1 luajit lua5.3 lua5.4 lua"
    if [[ "${MEMO_EMBEDDER:-}" == "gguf_ffi" ]]; then
        order="luajit lua5.1 lua5.3 lua5.4 lua"
    fi
    for cand in $order; do
        if command -v "$cand" >/dev/null; then echo "$cand"; return 0; fi
    done
    return 1
}

# Run a single luamemo.cli.api command.
# $1 = command name (e.g. "write", "search")
# stdin = JSON input object
# stdout = JSON result
api_call() {
    local cmd="$1"
    local lua; lua=$(find_lua) || {
        echo "memo: no Lua interpreter found (tried lua5.1, luajit, lua5.3, lua5.4, lua)" >&2
        exit 1
    }
    "$lua" -e "package.path='./?/init.lua;'..package.path; require('luamemo.cli.api').dispatch('${cmd}')"
}

# Build a JSON object from --key value pairs passed as arguments.
# --tags is split on commas into an array.
build_json() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        local key="${1#--}"
        local val="$2"
        if [[ "$key" == "tags" ]]; then
            local arr; arr=$(printf '%s' "$val" | jq -R 'split(",")|map(gsub("^\\s+|\\s+$";""))')
            json=$(printf '%s' "$json" | jq --argjson v "$arr" '. + {tags: $v}')
        else
            json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
        fi
        shift 2
    done
    printf '%s' "$json"
}

# ---------------------------------------------------------------------------
# Subcommands
# ---------------------------------------------------------------------------

cmd_write() {
    require_jq
    local body; body=$(build_json "$@")
    printf '%s' "$body" | api_call write | jq .
}

cmd_search() {
    require_jq
    local q="$1"; shift
    local json; json=$(jq -n --arg q "$q" '{q: $q}')
    while [[ $# -gt 0 ]]; do
        local key="${1#--}"; local val="$2"
        json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
        shift 2
    done
    printf '%s' "$json" | api_call search | jq .
}

cmd_recent() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        local key="${1#--}"; local val="$2"
        json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
        shift 2
    done
    printf '%s' "$json" | api_call recent | jq .
}

cmd_get() {
    require_jq
    jq -n --argjson id "$1" '{id: $id}' | api_call get | jq .
}

cmd_update() {
    require_jq
    local id="$1"; shift
    local body; body=$(build_json "$@")
    body=$(printf '%s' "$body" | jq --argjson id "$id" '. + {id: $id}')
    printf '%s' "$body" | api_call update | jq .
}

cmd_delete() {
    require_jq
    jq -n --argjson id "$1" '{id: $id}' | api_call delete | jq .
}

cmd_summarize() {
    require_jq
    local json='{}'
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dry-run)
                json=$(printf '%s' "$json" | jq '. + {dry_run: true}')
                shift ;;
            --*)
                local key="${1#--}"; key="${key//-/_}"
                local val="$2"
                json=$(printf '%s' "$json" | jq --arg k "$key" --arg v "$val" '. + {($k): $v}')
                shift 2 ;;
            *)
                echo "memo summarize: unknown arg: $1" >&2; exit 1 ;;
        esac
    done
    printf '%s' "$json" | api_call summarize | jq .
}

# ---------------------------------------------------------------------------
# Secrets subcommands
# ---------------------------------------------------------------------------

cmd_secret_store() {
    require_jq
    local name="" desc="" file=""
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --desc)  desc="$2";  shift 2 ;;
            --file)  file="$2";  shift 2 ;;
            -*)  echo "memo secret-store: unknown flag: $1" >&2; exit 1 ;;
            *)   name="$1"; shift ;;
        esac
    done
    if [[ -z "$name" ]]; then
        echo "Usage: memo secret-store NAME [--desc DESCRIPTION] [--file PATH]" >&2
        exit 1
    fi
    local value
    if [[ -n "$file" ]]; then
        value=$(cat "$file")
    else
        read -r -s -p "Secret value for \"${name}\": " value
        echo >&2
    fi
    if [[ -z "$value" ]]; then
        echo "memo secret-store: value cannot be empty" >&2
        exit 1
    fi
    local body; body=$(jq -n \
        --arg n "$name" \
        --arg v "$value" \
        --arg d "$desc" \
        '{name: $n, value: $v, description: (if $d == "" then null else $d end)}')
    value=""
    printf '%s' "$body" | api_call secret-store \
        | jq '{ok, secret: {id: .secret.id, name: .secret.name, description: .secret.description}}'
}

cmd_secret_list() {
    require_jq
    printf '{}' | api_call secret-list \
        | jq '[.secrets[] | {id, name, description, used_count, last_used_at, updated_at}]'
}

cmd_secret_delete() {
    require_jq
    if [[ -z "${1:-}" ]]; then
        echo "Usage: memo secret-delete NAME" >&2; exit 1
    fi
    jq -n --arg name "$1" '{name: $name}' | api_call secret-delete | jq .
}

cmd_secret_execute() {
    require_jq
    if [[ -z "${1:-}" ]] || [[ -z "${2:-}" ]]; then
        echo "Usage: memo secret-execute NAME URL [--method M] [--header K:V]..." >&2
        echo "                                   [--body TEXT]" >&2
        echo "                                   [--form FIELD=VALUE]..." >&2
        echo "                                   [--form-file FIELD:PATH]..." >&2
        echo "                                   [--timeout-ms N]" >&2
        exit 1
    fi
    local name="$1" url="$2"; shift 2
    local method="" timeout_ms="" body="" headers='{}'
    local -a form_fields=()
    local -a form_files=()
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --method)     method="$2";     shift 2 ;;
            --timeout-ms) timeout_ms="$2"; shift 2 ;;
            --body)       body="$2";       shift 2 ;;
            --header)
                local hkey="${2%%:*}" hval="${2#*:}"
                headers=$(printf '%s' "$headers" | jq --arg k "$hkey" --arg v "$hval" '. + {($k): $v}')
                shift 2 ;;
            --form)       form_fields+=("$2"); shift 2 ;;
            --form-file)  form_files+=("$2");  shift 2 ;;
            *) echo "memo secret-execute: unknown flag: $1" >&2; exit 1 ;;
        esac
    done

    local payload; payload=$(jq -n --arg name "$name" --arg url "$url" '{name: $name, url: $url}')
    [[ -n "$method"     ]] && payload=$(printf '%s' "$payload" | jq --arg v "$method"     '. + {method: $v}')
    [[ -n "$timeout_ms" ]] && payload=$(printf '%s' "$payload" | jq --argjson v "$timeout_ms" '. + {timeout_ms: $v}')
    [[ -n "$body"       ]] && payload=$(printf '%s' "$payload" | jq --arg v "$body"       '. + {body: $v}')
    if [[ "$headers" != "{}" ]]; then
        payload=$(printf '%s' "$payload" | jq --argjson v "$headers" '. + {headers: $v}')
    fi

    if [[ ${#form_fields[@]} -gt 0 ]] || [[ ${#form_files[@]} -gt 0 ]]; then
        local mp='{}'
        for kv in "${form_fields[@]}"; do
            local fk="${kv%%=*}" fv="${kv#*=}"
            mp=$(printf '%s' "$mp" | jq --arg k "$fk" --arg v "$fv" '. + {($k): $v}')
        done
        for kv in "${form_files[@]}"; do
            local fk="${kv%%:*}" fv="${kv#*:}"
            mp=$(printf '%s' "$mp" | jq --arg k "$fk" --arg v "$fv" '. + {($k): {file: $v}}')
        done
        payload=$(printf '%s' "$payload" | jq --argjson v "$mp" '. + {multipart: $v}')
    fi

    printf '%s' "$payload" | api_call secret-execute | jq .
}

# ---------------------------------------------------------------------------
# memo migrate
# ---------------------------------------------------------------------------

# Required lm_memories columns shared by _cmd_migrate_check and _cmd_doctor_check.
# Add new column names here when a migration introduces them.
_MEMO_REQUIRED_COLS=(
    id scope kind title body tags metadata embedding importance
    decay_rate was_truncated fts created_at updated_at
    tier consolidated_at
)

# Redact password from a postgresql:// URL for safe display in error messages.
_redact_url() {
    echo "$1" | sed 's|://\([^:]*\):[^@]*@|://\1:***@|'
}

# Assemble a postgresql:// URL from components, validating structural fields
# for URL-unsafe characters (@  /  #  ?) that would silently mis-parse the
# authority section.  The password is percent-encoded so those characters in
# credentials don't break the URL.  Prints the URL to stdout on success;
# prints an error to stderr and returns 1 when a component is invalid.
# Usage: _build_pg_url <user> <pass> <host> <port> <dbname>
_build_pg_url() {
    local _u="$1" _p="$2" _h="$3" _pt="$4" _db="$5"
    if [[ "$_u" =~ [@/#?] ]]; then
        echo "  \u2717 DB user contains URL-unsafe characters (@ / # ?) — enter MEMO_DB_URL manually." >&2
        return 1
    fi
    if [[ "$_h" =~ [@#?] ]]; then
        echo "  \u2717 DB host contains URL-unsafe characters (@ # ?) — enter MEMO_DB_URL manually." >&2
        return 1
    fi
    if [[ -n "$_pt" ]] && ! [[ "$_pt" =~ ^[0-9]+$ ]]; then
        echo "  \u2717 DB port '$_pt' is not numeric — enter MEMO_DB_URL manually." >&2
        return 1
    fi
    if [[ "$_db" =~ [/@#?] ]]; then
        echo "  \u2717 DB name contains URL-unsafe characters (/ @ # ?) — enter MEMO_DB_URL manually." >&2
        return 1
    fi
    # Percent-encode password characters that would break URL parsing.
    # Encode % first to avoid double-encoding subsequent replacements.
    local _p_enc
    _p_enc=$(printf '%s' "$_p" | sed 's/%/%25/g; s/@/%40/g; s/#/%23/g; s|/|%2F|g; s/?/%3F/g')
    printf 'postgresql://%s:%s@%s:%s/%s' "$_u" "$_p_enc" "$_h" "$_pt" "$_db"
}

# ---------------------------------------------------------------------------
# _cmd_migrate_sql: emit full idempotent schema SQL (migrations 001–011).
# Outputs vector(384) — callers pipe through sed to substitute embed_dim.
# ---------------------------------------------------------------------------
_cmd_migrate_sql() {
    cat <<'MIGRATE_EOF'
-- ==========================================================================
-- luamemo: full schema + migrations (generated by `memo migrate`)
-- All statements are idempotent -- safe to run on a fresh or existing DB.
-- ==========================================================================

-- migration 001 / schema ---------------------------------------------------

CREATE EXTENSION IF NOT EXISTS vector;

CREATE TABLE IF NOT EXISTS lm_memories (
    id              BIGSERIAL   PRIMARY KEY,
    scope           TEXT        NOT NULL,
    kind            TEXT        NOT NULL,
    title           TEXT        NOT NULL,
    body            TEXT        NOT NULL,
    tags            TEXT[]      NOT NULL DEFAULT '{}',
    metadata        JSONB       NOT NULL DEFAULT '{}'::jsonb,
    embedding       vector(384),
    importance      REAL        NOT NULL DEFAULT 1.0
                        CHECK (importance >= 0.0 AND importance <= 10.0),
    decay_rate      REAL        NOT NULL DEFAULT 0.0
                        CHECK (decay_rate >= 0.0 AND decay_rate <= 1.0),
    was_truncated   BOOLEAN     NOT NULL DEFAULT FALSE,
    tier            SMALLINT    NOT NULL DEFAULT 1,
    consolidated_at TIMESTAMPTZ,
    fts             tsvector GENERATED ALWAYS AS
                        (to_tsvector('english',
                            coalesce(title, '') || ' ' || coalesce(body, '')))
                    STORED,
    created_at      TIMESTAMPTZ NOT NULL DEFAULT now(),
    updated_at      TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS lm_memories_scope_idx ON lm_memories (scope);
CREATE INDEX IF NOT EXISTS lm_memories_kind_idx  ON lm_memories (kind);
CREATE INDEX IF NOT EXISTS lm_memories_tags_idx  ON lm_memories USING GIN (tags);
CREATE INDEX IF NOT EXISTS lm_memories_fts_idx   ON lm_memories USING GIN (fts);

-- Detect real[] embedding column (happens when the table was created before
-- the pgvector extension was installed — PostgreSQL silently used real[] as
-- a fallback).  Abort with a clear remediation command rather than crashing
-- on the HNSW CREATE INDEX below.
DO $luamemo_col_check$
DECLARE
    col_udt text;
BEGIN
    SELECT udt_name INTO col_udt
    FROM information_schema.columns
    WHERE table_schema = 'public'
      AND table_name   = 'lm_memories'
      AND column_name  = 'embedding';
    IF col_udt = '_float4' THEN
        RAISE EXCEPTION
            'lm_memories.embedding is typed real[] instead of vector. '
            'The pgvector extension was not installed when the table was first created. '
            'Fix with (replace N with your embed_dim, e.g. 384 or 1024): '
            'ALTER TABLE lm_memories ALTER COLUMN embedding TYPE vector(N) USING NULL; '
            'Then re-run: memo migrate | psql "$MEMO_DB_URL"';
    END IF;
END $luamemo_col_check$;

CREATE INDEX IF NOT EXISTS lm_memories_embedding_hnsw_idx
    ON lm_memories USING hnsw (embedding vector_cosine_ops);
CREATE INDEX IF NOT EXISTS lm_memories_was_truncated_idx
    ON lm_memories (was_truncated) WHERE lm_memories.was_truncated = TRUE;

CREATE OR REPLACE FUNCTION lm_memories_touch_updated_at()
RETURNS TRIGGER AS $$
BEGIN
    NEW.updated_at = now();
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS lm_memories_touch_updated_at_trg ON lm_memories;
CREATE TRIGGER lm_memories_touch_updated_at_trg
    BEFORE UPDATE ON lm_memories
    FOR EACH ROW
    EXECUTE FUNCTION lm_memories_touch_updated_at();

-- migration 002 / importance + decay ---------------------------------------

ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS importance  REAL NOT NULL DEFAULT 1.0;
ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS decay_rate  REAL NOT NULL DEFAULT 0.0;

ALTER TABLE lm_memories DROP CONSTRAINT IF EXISTS lm_memories_importance_range;
ALTER TABLE lm_memories ADD  CONSTRAINT lm_memories_importance_range
    CHECK (importance >= 0.0 AND importance <= 10.0);

ALTER TABLE lm_memories DROP CONSTRAINT IF EXISTS lm_memories_decay_rate_range;
ALTER TABLE lm_memories ADD  CONSTRAINT lm_memories_decay_rate_range
    CHECK (decay_rate >= 0.0 AND decay_rate <= 1.0);

-- migration 003 / knowledge-graph layer ------------------------------------

CREATE TABLE IF NOT EXISTS lm_kg_facts (
    id               BIGSERIAL PRIMARY KEY,
    scope            TEXT        NOT NULL,
    subject          TEXT        NOT NULL,
    predicate        TEXT        NOT NULL,
    object           TEXT        NOT NULL,
    valid_from       TIMESTAMPTZ NOT NULL DEFAULT now(),
    valid_until      TIMESTAMPTZ,
    source_memory_id BIGINT      REFERENCES lm_memories(id) ON DELETE SET NULL,
    created_at       TIMESTAMPTZ NOT NULL DEFAULT now()
);

CREATE INDEX IF NOT EXISTS lm_kg_facts_scope_idx   ON lm_kg_facts (scope);
CREATE INDEX IF NOT EXISTS lm_kg_facts_sp_idx       ON lm_kg_facts (subject, predicate);
CREATE INDEX IF NOT EXISTS lm_kg_facts_current_idx  ON lm_kg_facts (subject, predicate)
    WHERE valid_until IS NULL;

ALTER TABLE lm_kg_facts DROP CONSTRAINT IF EXISTS lm_kg_facts_validity_window;
ALTER TABLE lm_kg_facts ADD  CONSTRAINT lm_kg_facts_validity_window
    CHECK (valid_until IS NULL OR valid_until >= valid_from);

-- migration 004 / was_truncated flag ---------------------------------------

ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS was_truncated BOOLEAN NOT NULL DEFAULT FALSE;

-- migration 005 / composite index (scope, kind) ----------------------------

CREATE INDEX IF NOT EXISTS lm_memories_scope_kind_idx
    ON lm_memories (scope, kind);

-- migration 006 / temporal retrieval index ---------------------------------

CREATE INDEX IF NOT EXISTS lm_memories_created_at_scope_idx
    ON lm_memories (scope, created_at DESC);

-- migration 007 / observation consolidation --------------------------------

ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS consolidated_at TIMESTAMPTZ;

CREATE INDEX IF NOT EXISTS lm_memories_consolidated_at_idx
    ON lm_memories (scope, consolidated_at)
    WHERE consolidated_at IS NULL;

CREATE TABLE IF NOT EXISTS lm_observations (
    id              BIGSERIAL PRIMARY KEY,
    scope           TEXT    NOT NULL,
    body            TEXT    NOT NULL,
    proof_count     INTEGER NOT NULL DEFAULT 1
                        CHECK (proof_count >= 1),
    evidence_ids    BIGINT[] NOT NULL DEFAULT '{}',
    evidence_quotes TEXT[]  NOT NULL DEFAULT '{}',
    freshness_trend TEXT    NOT NULL DEFAULT 'new'
                        CHECK (freshness_trend IN
                            ('new', 'strengthening', 'stable', 'weakening', 'stale')),
    last_reinforced TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    created_at      TIMESTAMPTZ NOT NULL DEFAULT NOW(),
    importance      REAL    NOT NULL DEFAULT 0.5
                        CHECK (importance >= 0.0 AND importance <= 10.0),
    embedding       REAL[]
);

CREATE INDEX IF NOT EXISTS lm_observations_scope_idx
    ON lm_observations (scope);
CREATE INDEX IF NOT EXISTS lm_observations_reinforced_idx
    ON lm_observations (scope, last_reinforced DESC);

-- migration 008 / memory tiers ---------------------------------------------

-- Note: consolidated_at was already added in migration 007.
ALTER TABLE lm_memories ADD COLUMN IF NOT EXISTS tier SMALLINT NOT NULL DEFAULT 1;

UPDATE lm_memories SET tier = CASE
    WHEN importance < 0.3  THEN 0
    WHEN importance < 0.6  THEN 1
    WHEN importance < 0.85 THEN 2
    ELSE 3
END
WHERE tier = 1;

CREATE INDEX IF NOT EXISTS lm_memories_tier_scope_idx
    ON lm_memories (scope, tier);

-- migration 009 / reinforcement event log ----------------------------------

CREATE TABLE IF NOT EXISTS lm_reinforcements (
    id          BIGSERIAL PRIMARY KEY,
    memory_id   BIGINT NOT NULL REFERENCES lm_memories(id) ON DELETE CASCADE,
    scope       TEXT NOT NULL,
    event_type  TEXT NOT NULL CHECK (event_type IN
                    ('direct_command','mistake','reversal','praise','miss')),
    delta       REAL NOT NULL,
    note        TEXT,
    created_at  TIMESTAMPTZ NOT NULL DEFAULT NOW()
);

CREATE INDEX IF NOT EXISTS lm_reinforcements_memory_idx
    ON lm_reinforcements (memory_id);
